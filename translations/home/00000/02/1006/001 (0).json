        {
            "jpName": "オグリキャップ",
            "enName": "Oguri Cap",
            "jpText": "――肉まんの後で頼む。\nなぜなら……。",
            "enText": "Can it wait till after I finish this pork bun? \nAfter all…",
            "nextBlock": 4,
            "voiceIdx": 2,
            "pathId": 4837683511811005697,
            "blockIdx": 3
        },
        {
            "jpName": "オグリキャップ",
            "enName": "Oguri Cap",
            "jpText": "肉まんは、\nアツアツが美味しいからだ！",
            "enText": "Pork buns should be eaten \nwhen they're still hot!",
            "nextBlock": 5,
            "voiceIdx": 3,
            "pathId": -2410291108569696269,
            "blockIdx": 4
        },
        {
            "jpName": "バンブーメモリー",
            "enName": "Bamboo Memory",
            "jpText": "何言ってるんスか！？\nそんなのっ……！",
            "enText": "What are you saying?! Why…",
