            "pathId": -5520566763183095294,
            "blockIdx": 15
        },
        {
            "jpName": "エルコンドルパサー",
            "enName": "El Condor Pasa",
            "jpText": "スィ！　……あ、つけたくなったらいつでもエルの前には\r\n『世界最強』をつけてくださって構わないデスよ！！",
            "enText": "¡Sí! Oh, and if you feel like it, I wouldn't mind you taggin' \n\"the world's strongest racer\" to my name either!",
            "nextBlock": 17,
            "origClipLength": 272,
            "voiceIdx": 14,
            "animData": [
                {
                    "origLen": 229,
                    "pathId": -5341173763739703617
                },
                {
                    "origLen": 60,
                    "pathId": -8646310458302030178
                },
                {
                    "origLen": 304,
                    "pathId": -9159180490150078275
                },
                {
                    "origLen": 310,
                    "pathId": -4207350249028389211
                }
            ],
            "pathId": 3724959086079189850,
            "blockIdx": 16
        },
        {
            "jpName": "エルコンドルパサー",
            "enName": "El Condor Pasa",
            "jpText": "おっと、もう授業が始まりますデスね。\r\nチャオ、スぺちゃん！　またあとで！",
            "enText": "¡Anda! Class is about to start! ¡Chau, Spe! See ya later!",
            "nextBlock": 18,
            "origClipLength": 180,
            "voiceIdx": 15,
            "animData": [
                {
                    "origLen": 215,
                    "pathId": 2698353680886590099
                },
                {
                    "origLen": 186,
                    "pathId": -2207336320570635407
                },
                {
                    "origLen": 92,
                    "pathId": 2415650457591372399
                },
                {
                    "origLen": 20,
                    "pathId": -3227503384662273849
                },
                {
                    "origLen": 310,
                    "pathId": -7741326259636164022
                }
            ],
            "pathId": 7848308258210991398,
            "blockIdx": 17
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "あ、はいっ！　またあとで……！",
            "enText": "Y-Yeah, see you…!",
            "nextBlock": 19,
            "origClipLength": 157,
            "voiceIdx": 16,
            "animData": [
                {
                    "origLen": 154,
                    "pathId": -8439526335340412549
                },
                {
                    "origLen": 194,
                    "pathId": -4214436086949917737
