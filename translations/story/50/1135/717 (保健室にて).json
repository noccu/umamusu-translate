    "title": "保健室にて",
    "enTitle": "At the Infirmary",
    "text": [
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "ステイゴールドの調子が思わしくなく、\n保健室へと連れてきた。",
            "enText": "Stay Gold did not appear to be in the \nbest condition, so I brought her to the \ninfirmary.",
            "nextBlock": 2,
            "origClipLength": 84,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 95,
                    "pathId": -3789726501289697782
                },
                {
                    "origLen": 95,
                    "pathId": -6232363847580139047
                }
            ],
            "pathId": -5324917672604589421,
            "blockIdx": 1
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "悪いな、トレーナー。\nここまで付き合ってくれなくても、\n問題はなかったのに。",
            "enText": "Sorry about this, Trainer. You brought \nme all this way even though there's \nnothing to worry about.",
            "nextBlock": 3,
            "origClipLength": 94,
            "voiceIdx": 12,
            "choices": [
                {
                    "jpText": "心配だから……",
                    "enText": "I still am worried though…",
                    "nextBlock": 3
                }
            ],
            "animData": [
                {
                    "origLen": 52,
                    "pathId": 3417886032626421274
                },
                {
                    "origLen": 105,
                    "pathId": 5964339800237978253
                }
            ],
            "pathId": 6091542959480749971,
            "blockIdx": 2
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "そうか。まーちょっとした油断に、\n足をすくわれることもある。\nここは大人しく、休ませてもらうとするよ。",
            "enText": "I see. Well, one could never be too \ncareful. I'll behave and get a little \nrest here then.",
            "nextBlock": 4,
            "origClipLength": 111,
            "voiceIdx": 47,
            "choices": [
                {
                    "jpText": "おやすみ",
                    "enText": "Good night",
                    "nextBlock": 4
                }
            ],
            "animData": [
                {
                    "origLen": 84,
                    "pathId": -1659065015066299989
                },
                {
                    "origLen": 122,
                    "pathId": -6087508738280482216
                }
