            "pathId": 146804749075533966,
            "blockIdx": 1
        },
        {
            "jpName": "レースファンA",
            "enName": "Racing Fan A",
            "jpText": "メジロブライトはやっぱ\n距離が長いほうが強いはずだって！\n今日は『皐月賞』より絶対いいはず……！",
            "enText": "Meijiro Bright really shines on the longer \ntracks! She's totally gonna do way \nbetter here than in the Satsuki Sho…!",
            "nextBlock": 3,
            "origClipLength": 107,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 10,
                    "pathId": 4673341517166615294
