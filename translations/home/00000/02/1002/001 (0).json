    "text": [
        {
            "jpName": "タイキシャトル",
            "enName": "Taiki Shuttle",
            "jpText": "スズカ！　またまた、\r\nミステリーサークルを大発見デース！！",
            "enText": "Suzuka! It happened again! \nI found more crop circles!!",
            "nextBlock": 2,
            "voiceIdx": 0,
            "pathId": 1067282322015037673,
            "blockIdx": 1
        },
        {
            "jpName": "サイレンススズカ",
            "enName": "Silence Suzuka",
            "jpText": "ほ、本当に？　見間違えとかじゃ……。",
            "enText": "R-Really? Are you sure you're not just ——",
            "nextBlock": 3,
            "voiceIdx": 1,
            "pathId": -3818392829813048563,
            "blockIdx": 2
        },
        {
            "jpName": "タイキシャトル",
            "enName": "Taiki Shuttle",
            "jpText": "ブシに二言はナッシング！\r\nたしかにありマシタ！！",
            "enText": "I swear I wasn't imaginin' things! \nCross my heart!",
            "nextBlock": 4,
            "voiceIdx": 2,
            "pathId": 4179344133545469740,
            "blockIdx": 3
        },
        {
            "jpName": "タイキシャトル",
            "enName": "Taiki Shuttle",
            "jpText": "河川敷と公園の草むらに、\r\nナルトみたいなサークルがグルグル～っと！",
            "enText": "It was by the riverbank and in the tall grass \nby the park! There were these swirly-lookin' \ncircles in the grass!",
            "nextBlock": 5,
            "voiceIdx": 3,
            "pathId": 5115486612291162420,
            "blockIdx": 4
        },
        {
            "jpName": "サイレンススズカ",
            "enName": "Silence Suzuka",
            "jpText": "……え？\r\nどっちも私がトレーニングしてた場所だわ。",
            "enText": "…Huh? But I was training in both \nof those areas recently…",
            "nextBlock": 6,
            "voiceIdx": 4,
            "pathId": -3371137870207093847,
            "blockIdx": 5
        },
        {
            "jpName": "タイキシャトル",
            "enName": "Taiki Shuttle",
            "jpText": "ハッハァ～ン？\r\nさてはスズカがUFOを呼びましたネ？",
            "enText": "Oho? Does that mean you're \ncallin' the UFOs here?",
            "nextBlock": 7,
            "voiceIdx": 5,
            "pathId": 6816478081811217490,
            "blockIdx": 6
        },
        {
            "jpName": "サイレンススズカ",
            "enName": "Silence Suzuka",
            "jpText": "ふふ、まさか。\r\nきっと偶然に決まって――",
            "enText": "Hehehe, of course not. That's just—",
            "nextBlock": 8,
            "voiceIdx": 6,
            "pathId": -8898112095029143290,
            "blockIdx": 7
        },
        {
            "jpName": "サイレンススズカ",
            "enName": "Silence Suzuka",
            "jpText": "（あら……でも前に発見された場所も、\r\n私が立ち寄った場所、だった……かも……？）",
            "enText": "(Wait… I trained in the last place she found \ncircles in too. Does that… mean…)",
            "nextBlock": 9,
            "voiceIdx": 7,
            "pathId": -6934659260202704652,
            "blockIdx": 8
        },
        {
            "jpName": "サイレンススズカ",
            "enName": "Silence Suzuka",
            "jpText": "……ウ、ウソでしょ。\r\n本当に私が、UFOを……？",
            "enText": "N-No way… Am I really… summoning aliens?",
            "nextBlock": 10,
            "voiceIdx": 8,
            "pathId": -155386374409945199,
            "blockIdx": 9
        },
        {
            "jpName": "タイキシャトル",
            "enName": "Taiki Shuttle",
            "jpText": "オーケーオーケー！\r\n今度屋上で試してみまショー☆",
            "enText": "Only one way to find out! \nLet's go train on the roof!☆",
            "nextBlock": -1,
            "voiceIdx": 9,
            "pathId": -859186754271003621,
            "blockIdx": 10
        }
    ],
