    "text": [
        {
            "jpName": "実況",
            "enName": "Commentator",
            "jpText": "――第4コーナーを回って直線！！\n世代の頂点へ、夢が駆けるッ！！",
            "enText": "—Around the 4th corner and onto the \nstraights!! Who will stand at the top of \nthis generation! It's a dash for hopes \nand dreams!",
            "nextBlock": 2,
            "origClipLength": 86,
            "voiceIdx": -1,
            "pathId": 1016712263193905959,
            "blockIdx": 1
        },
        {
            "jpName": "ステゴのファンA",
            "enName": "Stego Fan A",
            "jpText": "いけ！！　ステイゴールドーーッ！！\nいけーーーーーーーーッ！！！",
            "enText": "Come On!!! Stay Goldーー!! \nLet's Goーーーーーーーー!!!",
