            "pathId": 7493522850351727548,
            "blockIdx": 53
        },
        {
            "jpName": "幼いアイ",
            "enName": "Young Ai",
            "jpText": "……うぐっ、ぐす！\nもういっかい！　明日もういっかいレースしよ！",
            "enText": "……Ugh, ghh! \nAgain! Tomorrow, let's race again!",
            "nextBlock": 55,
