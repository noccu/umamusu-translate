            ],
            "pathId": 1152519759266658830,
            "blockIdx": 6
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "『天皇賞（秋）』が近づくにつれ……\nその感覚が、より強くなっている気がする。",
            "enText": "",
            "nextBlock": 8,
            "origClipLength": 94,
            "voiceIdx": -1,
            "choices": [
                {
                    "jpText": "その集まっているものって、もしかして――",
                    "enText": "",
                    "nextBlock": 8
                }
            ],
            "pathId": -5264490345391691653,
            "blockIdx": 7
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "縁か、あるいは……――",
            "enText": "",
            "nextBlock": 9,
            "origClipLength": 59,
            "voiceIdx": 34,
            "animData": [
                {
                    "origLen": 138,
                    "pathId": 5719497827764090824
                },
                {
                    "origLen": 156,
                    "pathId": -7457308596959267020
                }
            ],
            "pathId": 4161590923773511782,
            "blockIdx": 8
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "……ま、考えてもわからんな。",
            "enText": "",
            "nextBlock": 10,
            "origClipLength": 63,
            "voiceIdx": -1,
            "choices": [
                {
                    "jpText": "だよな～……",
                    "enText": "",
                    "nextBlock": 10
                },
                {
                    "jpText": "だよね～……",
                    "enText": "",
                    "nextBlock": 10
                }
            ],
            "animData": [
                {
                    "origLen": 21,
                    "pathId": -1787960077926812842
                },
                {
                    "origLen": 74,
                    "pathId": -3657465308677329059
