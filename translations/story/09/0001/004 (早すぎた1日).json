                {
                    "origLen": 379,
                    "pathId": -8433683916523532505
                }
            ],
            "pathId": 5823584399665531601,
            "blockIdx": 10
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "え、ぁ、ぁ、え……！？",
            "enText": "Huh, ah, huh?!",
            "nextBlock": 12,
            "origClipLength": 79,
            "voiceIdx": 9,
            "animData": [
                {
                    "origLen": 50,
                    "pathId": -7779153578158544480
