            ],
            "pathId": 753163803218733929,
            "blockIdx": 35
        },
        {
            "jpName": "アーモンドアイ",
            "enName": "Almond Eye",
            "jpText": "妥協できない人は信頼できるわ。\n貴方がいればきっと、わたしはもっと強くなれる。……どう？",
            "enText": "Someone that is unwilling to compromise is someone \nthat I can trust. If you're with me, then without a \ndoubt, I will become even stronger. ……How about it?",
            "nextBlock": 37,
            "origClipLength": 302,
            "voiceIdx": 16,
            "choices": [
                {
                    "jpText": "――お、俺でよければもちろん！",
                    "enText": "——I-if you're fine with me!",
                    "nextBlock": 37
                },
                {
                    "jpText": "――わ、私でよければもちろん！",
                    "enText": "——I-if you're fine with me!",
