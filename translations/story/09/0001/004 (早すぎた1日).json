            "pathId": -3786675888096079762,
            "blockIdx": 26
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "（って私、数学はそもそも基礎から危ういんだったぁ～！！）",
            "enText": "(Or at least that's what I'd say if I <i>knew</i> the basics!!)",
            "nextBlock": 28,
            "origClipLength": 160,
            "voiceIdx": 25,
            "animData": [
