            "pathId": -4201398158615630039,
            "blockIdx": 19
        },
        {
            "jpName": "先生A",
            "enName": "Teacher A",
            "jpText": "では問5、スペシャルウィークさん、答えてください。\r\n……スぺシャルウィークさん？　聞いていますか？",
            "enText": "All right, then, Special Week, please answer number five… \nSpecial Week? Hey, are you listening?",
            "nextBlock": 21,
            "origClipLength": 257,
            "voiceIdx": 18,
            "animData": [
                {
                    "origLen": 316,
                    "pathId": 2140449730522149944
                },
                {
                    "origLen": 358,
                    "pathId": -3172135739518765995
                }
            ],
            "pathId": 4811950447942919158,
            "blockIdx": 20
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "へぁっ、はい！？　す、すみません、板書写してました……！",
            "enText": "Y-Yes?! S-Sorry, I was copying notes from the board!",
            "nextBlock": 22,
            "origClipLength": 140,
            "voiceIdx": 19,
            "animData": [
                {
                    "origLen": 60,
                    "pathId": -5222389142395611122
