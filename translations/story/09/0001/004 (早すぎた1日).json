                {
                    "origLen": 68,
                    "pathId": -6672778910609756600
                }
            ],
            "pathId": -7051271821218930535,
            "blockIdx": 21
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "（は、早いぃ～！　向こうだと私1人だったし、ペース合わせて\r\nもらえたけど……都会の授業ペース、こんなに早いんだべ！？）",
            "enText": "(So fast! Back home, the teacher always met my pace \nsince I was the only student. I didn't think classes in the \nbig city'd be goin' a mile a minute!)",
            "nextBlock": 23,
            "origClipLength": 321,
            "voiceIdx": 20,
            "animData": [
                {
                    "origLen": 83,
                    "pathId": 3457579768707177722
                },
                {
                    "origLen": 21,
                    "pathId": 6397977388411595459
                }
            ],
            "pathId": -3992431171250959790,
            "blockIdx": 22
        },
        {
            "jpName": "エルコンドルパサー",
            "enName": "El Condor Pasa",
            "jpText": "まずいまずいまずいデスよスぺちゃんっ！\r\n次の数学の授業、小テストあるんでした！！",
            "enText": "This is bad, bad, bad, Spe! There's gonna be \na quiz in math class next!",
            "nextBlock": 24,
            "origClipLength": 202,
            "voiceIdx": 21,
            "animData": [
                {
                    "origLen": 158,
                    "pathId": -9029524012178241856
                },
                {
                    "origLen": 21,
                    "pathId": 7266487580891276767
                },
                {
                    "origLen": 50,
                    "pathId": 1948331020599343604
                },
                {
                    "origLen": 20,
                    "pathId": -4000505757168629715
                },
                {
                    "origLen": 232,
                    "pathId": 5705562585871701888
                }
            ],
            "pathId": -8799133043187663770,
            "blockIdx": 23
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "えっえっ、小テストですか！？\r\nどどどうしよう、私準備なんか全然っ……！！",
            "enText": "Wh-what?! A quiz?! Wh-wh-what should I do? \nI'm not ready at all!",
            "nextBlock": 25,
            "origClipLength": 194,
            "voiceIdx": 22,
            "animData": [
                {
                    "origLen": 39,
                    "pathId": 700698802651509732
                },
                {
                    "origLen": 21,
                    "pathId": -865323147509476065
                },
                {
                    "origLen": 206,
                    "pathId": -1116290957924727133
                },
                {
                    "origLen": 120,
                    "pathId": 3996233417888897676
                }
            ],
            "pathId": -8047708587481062838,
            "blockIdx": 24
        },
        {
            "jpName": "グラスワンダー",
            "enName": "Grass Wonder",
            "jpText": "こんな時こそ泰然と構えましょう、スぺちゃん。\r\nテスト内容は基礎的なものばかりですから、大丈夫ですよ。",
            "enText": "It's times like these where one must remain calm, Spe. \nThe contents of the test will all be fundamentals, \nso you'll be fine.",
            "nextBlock": 26,
            "origClipLength": 269,
            "voiceIdx": 23,
            "animData": [
                {
                    "origLen": 191,
                    "pathId": 6410161182690259323
                },
                {
                    "origLen": 266,
                    "pathId": 8621554118374471563
                },
                {
                    "origLen": 108,
                    "pathId": 1957568545747000063
                },
                {
                    "origLen": 174,
                    "pathId": 8651808635612435298
                }
            ],
            "pathId": 3156174486350579141,
            "blockIdx": 25
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "グラスちゃん……！　うぅぅ、ありがとうございます～！\r\nそうですよね、基礎ならきっと……！！",
            "enText": "Grass… Oh, thank you so much! \nThat's right, I should be okay with the basics…!",
            "nextBlock": 27,
            "origClipLength": 241,
            "voiceIdx": 24,
            "animData": [
                {
                    "origLen": 60,
                    "pathId": -6524682845104524404
                },
                {
                    "origLen": 120,
                    "pathId": -7269165662997011017
                },
