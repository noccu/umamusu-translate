            "pathId": 6387563060609452018,
            "blockIdx": 14
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "ああ。そうみたいだな。",
            "enText": "Yeah. It seems like that.",
            "nextBlock": 16,
            "origClipLength": 59,
            "voiceIdx": 37,
            "animData": [
                {
                    "origLen": 62,
                    "pathId": 7276039283565855816
