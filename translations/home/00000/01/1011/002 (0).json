    "text": [
        {
            "jpName": "グラスワンダー",
            "enName": "Grass Wonder",
            "jpText": "……ふふ♪",
            "enText": "…Hehe♪",
            "nextBlock": 2,
            "voiceIdx": 0,
            "pathId": 4880894176296491797,
            "blockIdx": 1
        },
        {
            "jpName": "グラスワンダー",
            "enName": "Grass Wonder",
            "jpText": "育てているコケリウムが、\n今朝がたお花を咲かせたんです。",
            "enText": "I was looking at my terrarium this morning, \nand I noticed the moss had sprouted flowers.",
            "nextBlock": 3,
            "voiceIdx": 1,
            "pathId": -6709433582668797208,
            "blockIdx": 2
        },
        {
            "jpName": "グラスワンダー",
            "enName": "Grass Wonder",
            "jpText": "森に似て、毎日少なからず\n変化はあるものなのですが――",
            "enText": "Just like a real forest, every day \nbrings new, small changes…",
            "nextBlock": 4,
            "voiceIdx": 2,
            "pathId": 1288699511252143684,
            "blockIdx": 3
        },
        {
            "jpName": "グラスワンダー",
            "enName": "Grass Wonder",
            "jpText": "こうしてお花が咲いてくれると、\nやっぱり嬉しいものですね～。",
            "enText": "But there's something about flowers \nthat just sparks joy, isn't there?",
            "nextBlock": 5,
            "voiceIdx": 3,
            "pathId": -6187948631334268845,
            "blockIdx": 4
        },
        {
            "jpName": "グラスワンダー",
            "enName": "Grass Wonder",
            "jpText": "移ろいゆく森がそこにあって、\n息をしているんだと実感できて。",
            "enText": "It truly makes you realize that there's a little \nworld down there, living and changing.",
            "nextBlock": 6,
            "voiceIdx": 4,
            "pathId": -8603951799887963234,
            "blockIdx": 5
        },
        {
            "jpName": "グラスワンダー",
            "enName": "Grass Wonder",
            "jpText": "よかったら、トレーナーさんも\nぜひチャレンジしてみてください♪",
            "enText": "If you ever wish to give terrariums a try, \nI highly recommend it♪",
            "nextBlock": -1,
            "voiceIdx": 5,
            "pathId": -5525568277483331100,
            "blockIdx": 6
        }
    ],
