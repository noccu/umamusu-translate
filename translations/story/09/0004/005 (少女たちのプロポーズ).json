            "pathId": 1934855278629689149,
            "blockIdx": 28
        },
        {
            "jpName": "ビューティー安心沢",
            "enName": "Beauty Anshinzawa",
            "jpText": "ンフフ、構わないわよ♪\r\nアナタなりのプロポーズ、受け取ったわ～！",
            "enText": "Hehe, I don't mind at all!♪ \nI accept your unique proposal!",
            "nextBlock": 30,
            "origClipLength": 210,
