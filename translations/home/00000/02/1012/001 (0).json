    "text": [
        {
            "jpName": "ヒシアマゾン",
            "enName": "Hishi Amazon",
            "jpText": "ブライアン！\r\nアタシとタイマン勝負だ！",
            "enText": "Brian! You and me — one-on-one!",
            "nextBlock": 2,
            "voiceIdx": 0,
            "pathId": 4503173763258452451,
            "blockIdx": 1
        },
        {
            "jpName": "ナリタブライアン",
            "enName": "Narita Brian",
            "jpText": "……断る。",
            "enText": "Not happening.",
            "nextBlock": 3,
            "voiceIdx": 1,
            "pathId": -5619134907702561581,
            "blockIdx": 2
        },
        {
            "jpName": "ヒシアマゾン",
            "enName": "Hishi Amazon",
            "jpText": "はぁあ！？\r\nなんだい、その気の抜けた返事は！",
            "enText": "Huh?! Wow, way to kill the mood!",
            "nextBlock": 4,
            "voiceIdx": 2,
            "pathId": 999146129621750768,
            "blockIdx": 3
        },
        {
            "jpName": "ヒシアマゾン",
            "enName": "Hishi Amazon",
            "jpText": "大体、アンタはいつも……って、んん？",
            "enText": "I mean, usually you'd be more… Huh?",
            "nextBlock": 5,
            "voiceIdx": 3,
            "pathId": 8658574833985725584,
            "blockIdx": 4
        },
        {
            "jpName": "ヒシアマゾン",
            "enName": "Hishi Amazon",
            "jpText": "……ほんとに気が抜けてる感じがするね。\r\nもしかして何かあったのかい？",
            "enText": "Wait… You seem kinda down in the dumps… \nSomething happen?",
            "nextBlock": 6,
            "voiceIdx": 4,
            "pathId": 3211932022546751046,
            "blockIdx": 5
        },
        {
            "jpName": "ナリタブライアン",
            "enName": "Narita Brian",
            "jpText": "……アマさんには関係ない。",
            "enText": "…None of your business.",
            "nextBlock": 7,
            "voiceIdx": 5,
            "pathId": 4190550775340441273,
            "blockIdx": 6
        },
        {
            "jpName": "ヒシアマゾン",
            "enName": "Hishi Amazon",
            "jpText": "はっ！　言うと思ったよ。\r\nけど、気づいちまった以上、\n放っておけないタチでね。",
            "enText": "Ha! Figured you'd say that! But unfortunately \nfor you, I can't just leave you alone now.",
            "nextBlock": 8,
            "voiceIdx": 6,
            "pathId": -6473781866061166495,
            "blockIdx": 7
        },
        {
            "jpName": "ヒシアマゾン",
            "enName": "Hishi Amazon",
            "jpText": "……言ってみなよ。\r\nアタシで力になれることなら、\n協力してやるからさ。",
            "enText": "Go ahead… lay it on me. If there's something \nI can do for you, I'll do it.",
            "nextBlock": 9,
            "voiceIdx": 7,
            "pathId": -8298598208171802899,
            "blockIdx": 8
        },
        {
            "jpName": "ナリタブライアン",
            "enName": "Narita Brian",
            "jpText": "…………。\r\n……購買部で、焼きそばパンが\n売り切れててな。",
            "enText": "…The school store ran out of yakisoba dogs.",
            "nextBlock": 10,
            "voiceIdx": 8,
            "pathId": -2511868222258418757,
            "blockIdx": 9
        },
        {
            "jpName": "ヒシアマゾン",
            "enName": "Hishi Amazon",
            "jpText": "食いたかっただけかい！！",
            "enText": "<i>THAT'S</i> what's got you down?!",
            "nextBlock": -1,
            "voiceIdx": 9,
            "pathId": -2198420088112942918,
            "blockIdx": 10
        }
    ],
