                    "origLen": 13,
                    "pathId": -6495185668371620948
                }
            ],
            "pathId": -1147353560963103481,
            "blockIdx": 20
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "だったら面白いんだがね。\n……ま、先の楽しみにとっておくか。",
            "enText": "It'd be pretty interesting if that was the \ncase… Well, let's put that conversation \naside for now.",
            "nextBlock": 22,
            "origClipLength": 84,
            "voiceIdx": 0,
            "choices": [
                {
                    "jpText": "この夏で、もっと力をつけよう",
                    "enText": "Let's get even stronger this summer",
                    "nextBlock": 22
                }
            ],
            "animData": [
                {
                    "origLen": 49,
                    "pathId": -3025034879324218852
                },
                {
                    "origLen": 95,
                    "pathId": 6161419155040298349
                },
                {
                    "origLen": 67,
