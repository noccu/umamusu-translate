                    "origLen": 20,
                    "pathId": 1725060648587032615
                }
            ],
            "pathId": -2511610638475030993,
            "blockIdx": 39
        },
        {
            "jpName": "アーモンドアイ",
            "enName": "Almond Eye",
            "jpText": "勝負は……！　ここから――！\n……っ、たぁあああっ！！",
            "enText": "The battle starts……! Right here――!! \n……Taaaaaaa!!",
            "nextBlock": 41,
