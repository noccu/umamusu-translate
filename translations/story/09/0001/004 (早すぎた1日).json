            "pathId": -5230601386787432476,
            "blockIdx": 9
        },
        {
            "jpName": "エルコンドルパサー",
            "enName": "El Condor Pasa",
            "jpText": "歓迎、歓迎、大歓迎ッ！　待っていましたリングイン！\r\n新たなライバル堂々参上！　スペシャルウィークさん、ようこそっ！",
            "enText": "Hello, greetings, and salutations! I've been waiting \nfor our bold new challenger to step into the ring! \nBienvenida, Special Week!",
            "nextBlock": 11,
            "origClipLength": 284,
            "voiceIdx": 8,
            "animData": [
                {
                    "origLen": 371,
                    "pathId": -4749440589011740048
                },
                {
                    "origLen": 20,
                    "pathId": 8335278232961124339
