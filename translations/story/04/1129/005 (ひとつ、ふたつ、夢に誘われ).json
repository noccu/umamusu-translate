            "pathId": 294321594284796749,
            "blockIdx": 10
        },
        {
            "jpName": "アーモンドアイ",
            "enName": "Almond Eye",
            "jpText": "わたしが試した時は、効果があったのに……！\nなにが足りなかったのかしら？",
            "enText": "When I tried it out, it worked so well for me though……! \nDid we skimp too much on something?",
            "nextBlock": 12,
            "origClipLength": 237,
            "voiceIdx": 9,
            "choices": [
                {
                    "jpText": "これ以上は悪いし……自分でなんとかするよ",
                    "enText": "……I'll just handle it on my own",
                    "nextBlock": 12
                }
            ],
            "animData": [
                {
                    "origLen": 253,
                    "pathId": -7017905985372360501
                },
                {
                    "origLen": 20,
                    "pathId": -6872864271273962448
