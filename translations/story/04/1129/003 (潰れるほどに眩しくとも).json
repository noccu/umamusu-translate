            ],
            "pathId": 949458841334032191,
            "blockIdx": 42
        },
        {
            "jpName": "アーモンドアイ",
            "enName": "Almond Eye",
            "jpText": "わたしの、勝ちよ！",
            "enText": "It's my victory!",
            "nextBlock": 44,
            "origClipLength": 72,
            "voiceIdx": 26,
            "animData": [
                {
                    "origLen": 120,
                    "pathId": 1117867435048522818
                }
            ],
            "pathId": 3858257792784042902,
            "blockIdx": 43
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "静まり返ったターフからは、囁き声すら聞こえない。",
            "enText": "The turf was dead silent.",
            "nextBlock": 45,
            "origClipLength": 76,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 105,
                    "pathId": 1865975225103324939
                }
            ],
            "pathId": -1146657476796999686,
            "blockIdx": 44
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "――勝てたら彼女に駆け寄り、『おめでとう！』と声をかけよう。\nそう心に決めていたのに、なぜか足が動かない。",
            "enText": "――I wanted to run up and say 『Congratulations!』 to her. \nBut, even though I wanted to, my legs wouldn't move for some reason.",
            "nextBlock": 46,
            "origClipLength": 114,
            "voiceIdx": -1,
            "choices": [
                {
                    "jpText": "（俺は……隣で彼女の日々を見てきた）",
                    "enText": "(I……had been with her all these days)",
                    "nextBlock": 46
                },
                {
                    "jpText": "（私は……隣で彼女の日々を見てきた）",
                    "enText": "(I……had been with her all these days)",
                    "nextBlock": 46
                }
            ],
            "animData": [
                {
                    "origLen": 139,
                    "pathId": -8745465044256077084
