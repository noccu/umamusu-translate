                {
                    "origLen": 124,
                    "pathId": 4087039961623541440
                },
                {
                    "origLen": 127,
                    "pathId": 6335316189288991711
                },
                {
                    "origLen": 124,
                    "pathId": -3877160950262223970
                },
                {
                    "origLen": 149,
                    "pathId": -939630333317860945
                }
            ],
            "pathId": 8610018902972187923,
            "blockIdx": 3
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "……ついに迎えた『日本ダービー』。\nいちトレーナーとして、興奮を抑えきれない。",
            "enText": "It's finally the day of the Japan Derby… \nI may just be a mere trainer, but even I \ncan't seem to contain the excitement \npulsing through my veins.",
            "nextBlock": 5,
            "origClipLength": 95,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 13,
                    "pathId": -6937665341054288759
                },
                {
                    "origLen": 13,
                    "pathId": 7221875640125300014
                },
                {
                    "origLen": 13,
                    "pathId": -1492663412024582309
                },
                {
                    "origLen": 13,
                    "pathId": -7296387333578669040
                },
                {
                    "origLen": 13,
                    "pathId": 3080572476693197201
                }
            ],
            "pathId": -2165745531667128376,
            "blockIdx": 4
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "その一方で――",
            "enText": "On the other hand…",
            "nextBlock": 6,
            "origClipLength": 54,
            "voiceIdx": -1,
            "pathId": 6204840323545980389,
            "blockIdx": 5
        },
