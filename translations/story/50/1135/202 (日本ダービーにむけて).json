        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "ふふっ……ははっ……\nははははははっ……！",
            "enText": "<i>Hehe…… Hahah…… \nHahahahahahaha……!</i>",
            "nextBlock": 10,
