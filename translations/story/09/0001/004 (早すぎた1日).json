                {
                    "origLen": 379,
                    "pathId": 7083444503606305044
                }
            ],
            "pathId": -5224795977433589374,
            "blockIdx": 11
        },
        {
            "jpName": "グラスワンダー",
            "enName": "Grass Wonder",
            "jpText": "あぁ～……すみません、驚かせてしまって。\r\nあとでよ～く言い聞かせておきますので。",
            "enText": "Oh… Do excuse her for startling you. \nI'll be sure to give her a stern talking to afterwards.",
            "nextBlock": 13,
            "origClipLength": 254,
            "voiceIdx": 10,
            "animData": [
                {
                    "origLen": 199,
                    "pathId": 7893205260325068505
