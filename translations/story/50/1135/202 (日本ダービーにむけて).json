            "pathId": -6055308901523213295,
            "blockIdx": 2
        },
        {
            "jpName": "レースファンB",
            "enName": "Racing Fan B",
            "jpText": "ステイゴールド、今日も頑張ってほしいなぁ。\n『皐月賞』から\nなんかずっと気になってるんだよね……。",
            "enText": "I really want Stay Gold to do her best \ntoday. I've become interested in her \nfeats ever since her performance at \nthe Satsuki Sho…",
            "nextBlock": 4,
            "origClipLength": 108,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 127,
                    "pathId": 6273744985397601473
