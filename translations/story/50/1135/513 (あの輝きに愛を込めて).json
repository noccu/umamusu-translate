            "pathId": -312469238111942520,
            "blockIdx": 18
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "ありがとうな。確かに受け取った。\n――さて、どこにつけるかな？　ふふ。",
            "enText": "I'll accept this with my gratitude. Now, I \nwonder where should I put this patch? \n<i>Hehe.</i>",
            "nextBlock": 20,
            "origClipLength": 90,
            "voiceIdx": 12,
            "animData": [
