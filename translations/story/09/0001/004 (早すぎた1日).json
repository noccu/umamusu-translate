            "pathId": -1682639703094169846,
            "blockIdx": 18
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "（お友だち、もうできちゃったかも……！\r\nよぉ～し、この調子で授業もトレーニングも……！）",
            "enText": "(Did I just make some friends? Yeees! \nI should keep this up for class and training too!)",
            "nextBlock": 20,
            "origClipLength": 219,
            "voiceIdx": 17,
            "animData": [
                {
                    "origLen": 80,
                    "pathId": 357137087078942349
