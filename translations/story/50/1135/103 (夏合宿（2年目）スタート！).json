                },
                {
                    "origLen": 88,
                    "pathId": 1455348366179851417
                },
                {
                    "origLen": 88,
                    "pathId": 5691605880240106423
                }
            ],
            "pathId": 2946123102353964376,
            "blockIdx": 16
        },
        {
            "jpName": "メジロマックイーン",
            "enName": "Mejiro McQueen",
            "jpText": "ブライトでしたら、彼女なりの方法で\n研鑽するつもりのようですわね。",
            "enText": "I believe Bright is diligently taking \nupon her training in her own way.",
            "nextBlock": 18,
            "origClipLength": 88,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 99,
                    "pathId": -3622313419242701135
                },
                {
                    "origLen": 99,
                    "pathId": 5884010123906466273
                },
                {
                    "origLen": 64,
                    "pathId": -6712401647262243100
                },
                {
                    "origLen": 99,
                    "pathId": -5055558922978811712
                }
            ],
            "pathId": 3271533239627088782,
            "blockIdx": 17
        },
        {
            "jpName": "メジロマックイーン",
            "enName": "Mejiro McQueen",
            "jpText": "……あの子、なにか少し変わりましたわ。",
            "enText": "…That girl, something has slightly \nchanged within her.",
            "nextBlock": 19,
            "origClipLength": 69,
            "voiceIdx": 76,
            "animData": [
                {
                    "origLen": 13,
                    "pathId": 3542962087095344109
                },
                {
                    "origLen": 13,
                    "pathId": -5446097333915833441
                },
                {
                    "origLen": 13,
                    "pathId": -4750212993850012807
                },
                {
                    "origLen": 13,
                    "pathId": 2012588344667023789
                },
                {
                    "origLen": 111,
                    "pathId": -8916087931823330431
                },
                {
                    "origLen": 111,
                    "pathId": -4434789514806412016
                },
                {
                    "origLen": 111,
                    "pathId": -1515970569341625642
                },
                {
                    "origLen": 111,
                    "pathId": 1537349098403777566
                }
            ],
            "pathId": 811935752385270846,
            "blockIdx": 18
        },
        {
            "jpName": "メジロマックイーン",
            "enName": "Mejiro McQueen",
            "jpText": "以前から芯の強いウマ娘だとは\n思っていましたが、ここ最近は\n一段と逞しくなったというべきでしょうか――",
            "enText": "I have always thought of her as a strong \nwilled girl, yet lately, would it be more \nfitting to say that her resolve has \nbecome indomitable?",
            "nextBlock": 20,
            "origClipLength": 111,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 122,
                    "pathId": 2014304952865513030
                },
                {
                    "origLen": 122,
                    "pathId": -4669706611254096207
                },
                {
                    "origLen": 122,
                    "pathId": 7590983059499155847
                },
                {
                    "origLen": 122,
                    "pathId": 1686516877429207428
                }
            ],
            "pathId": 6087054921075043794,
            "blockIdx": 19
        },
        {
            "jpName": "メジロマックイーン",
            "enName": "Mejiro McQueen",
            "jpText": "――……貴方と走って、\nなにか影響されたのかもしれませんわね。",
            "enText": "…I believe that it may have possibly \nbeen your influence that caused this \nchange within her.",
            "nextBlock": 21,
            "origClipLength": 85,
            "voiceIdx": 0,
            "animData": [
                {
                    "origLen": 127,
                    "pathId": 1472013005389759572
                },
                {
                    "origLen": 127,
                    "pathId": 5308629872205771999
                },
                {
                    "origLen": 127,
                    "pathId": 2165838161466840092
                },
                {
                    "origLen": 127,
                    "pathId": 7496214116022973344
                },
                {
                    "origLen": 13,
                    "pathId": 8639760244790704808
                },
                {
                    "origLen": 13,
                    "pathId": 4672352850426838674
                },
                {
