            "pathId": 129212711400422993,
            "blockIdx": 2
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "だな。こうも暑いんじゃあ、\n旅の歩みも鈍くなるってもんだ。",
            "enText": "",
            "nextBlock": 4,
            "origClipLength": 82,
            "voiceIdx": 47,
            "animData": [
