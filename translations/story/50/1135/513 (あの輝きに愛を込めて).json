            "blockIdx": 20
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "なあ、あんた！　キノコ狩りの帰りか？\n籠の中……美味そうなキノコがいっぱいだ。",
            "enText": "Hey there! Did you just go mushroom \nforaging? Your basket… there's so \nmany yummy looking mushrooms \nin there.",
            "nextBlock": 22,
            "origClipLength": 95,
            "voiceIdx": 53,
            "animData": [
                {
                    "origLen": 68,
                    "pathId": -672909912358595227
