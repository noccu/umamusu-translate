            "pathId": 7279706652072804922,
            "blockIdx": 13
        },
        {
            "jpName": "黒く大きな影",
            "enName": "Tall Dark Shadow",
            "jpText": "――――",
            "enText": "————",
            "nextBlock": 15,
            "origClipLength": 50,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 61,
                    "pathId": -3597907862404898368
