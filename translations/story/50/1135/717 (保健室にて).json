            ],
            "pathId": -713470281229428678,
            "blockIdx": 4
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "ん……？　ここは……。",
            "enText": "<i>Hm……?</i> This is……",
            "nextBlock": 6,
            "origClipLength": 59,
            "voiceIdx": 20,
            "animData": [
                {
                    "origLen": 13,
                    "pathId": -4188830269211357797
                },
