            "blockIdx": 1
        },
        {
            "jpName": "アナウンス",
            "enName": "Announcer",
            "jpText": "『――お客様にお知らせいたします。\nただいま、線路内に鹿の群れが侵入したため\n全線、運転を見合わせて……』",
            "enText": "\"——Announcement to all passengers. \nPresently, a herd of deers have bypassed \nonto the train tracks. All services are hereby \nsuspen—\"",
            "nextBlock": 3,
            "origClipLength": 114,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 89,
                    "pathId": 1495379461942241458
