            "pathId": -2694889503790008009,
            "blockIdx": 15
        },
        {
            "jpName": "店主のおじさん",
            "enName": "Elderly  Storekeeper",
            "jpText": "いや、待たせて悪いな！\nほれ、これを受け取ってくれないか。",
            "enText": "Whew, apologies for the wait! \nHere, would you accept this?",
            "nextBlock": 17,
            "origClipLength": 82,
            "voiceIdx": -1,
            "choices": [
                {
                    "jpText": "これは……アップリケ？",
                    "enText": "This is… An embroidered patch?",
