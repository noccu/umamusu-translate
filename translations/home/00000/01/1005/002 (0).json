    "text": [
        {
            "jpName": "フジキセキ",
            "enName": "Fuji Kiseki",
            "jpText": "おや？\r\nちょっとお疲れかな、トレーナーさん。",
            "enText": "Oh dear, someone looks tired.",
            "nextBlock": 2,
            "voiceIdx": 0,
            "pathId": -9146304294052937573,
            "blockIdx": 1
        },
        {
            "jpName": "フジキセキ",
            "enName": "Fuji Kiseki",
            "jpText": "そんな顔をしないでほしいな。\r\n私は、君の笑った顔が1番好きなんだ――",
            "enText": "I just hate to see you like this… \nI like you best when you're smiling…",
            "nextBlock": 3,
            "voiceIdx": 1,
            "pathId": 5752033614698212104,
            "blockIdx": 2
        },
        {
            "jpName": "フジキセキ",
            "enName": "Fuji Kiseki",
            "jpText": "……なーんてね♪",
            "enText": "Eeend scene♪",
            "nextBlock": 4,
            "voiceIdx": 2,
            "pathId": -5492326561416706847,
            "blockIdx": 3
        },
        {
            "jpName": "フジキセキ",
            "enName": "Fuji Kiseki",
            "jpText": "後輩が夢中になっている少女漫画の台詞だよ。\r\n結構キマっていただろう？",
            "enText": "I found that line in one of the romance \nmanga my juniors are so enamored with \nthese days. How did I do?",
            "nextBlock": 5,
            "voiceIdx": 3,
            "pathId": -8262914265837660652,
            "blockIdx": 4
        },
        {
            "jpName": "フジキセキ",
            "enName": "Fuji Kiseki",
            "jpText": "驚かせて悪かったね。\r\nでも、さっきの言葉は嘘じゃないよ。",
            "enText": "I do apologize for the scare. But I can \nassure you that it wasn't a lie.",
            "nextBlock": 6,
            "voiceIdx": 4,
            "pathId": -6401960257627032072,
            "blockIdx": 5
        },
        {
            "jpName": "フジキセキ",
            "enName": "Fuji Kiseki",
            "jpText": "トレーナーさんに元気でいてほしいのは、\r\n本当だからさ。",
            "enText": "After all, I would love nothing more than \nfor you to be happy and full of life.",
            "nextBlock": -1,
            "voiceIdx": 5,
            "pathId": -5882944371507855632,
            "blockIdx": 6
        }
    ],
    "modified": 1775505537,
    "humanTl": true
}