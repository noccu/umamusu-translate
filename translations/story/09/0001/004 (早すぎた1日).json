        {
            "jpName": "グラスワンダー",
            "enName": "Grass Wonder",
            "jpText": "私はグラスワンダー、この子はエルコンドルパサーです。\r\nよろしくお願いしますね、スペシャルウィークさん。",
            "enText": "I'm Grass Wonder, and this is El Condor Pasa. \nIt's a pleasure to meet you, Special Week.",
            "nextBlock": 15,
            "origClipLength": 268,
            "voiceIdx": 12,
            "animData": [
                {
                    "origLen": 286,
                    "pathId": 5634776498087069055
                },
                {
                    "origLen": 20,
                    "pathId": -631301916867995690
                },
                {
                    "origLen": 123,
                    "pathId": -8970248419026775923
