            "blockIdx": 9
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "ハーッハッハッハッハ！！",
            "enText": "<i>Haahahahhahahah!!</i>",
            "nextBlock": 11,
            "origClipLength": 73,
            "voiceIdx": 1,
            "choices": [
                {
                    "jpText": "ど、どうした！？",
                    "enText": "A-A-Are you alright!?",
                    "nextBlock": 11
                },
                {
                    "jpText": "ど、どうしたの！？",
                    "enText": "A-A-Are you alright!?",
                    "nextBlock": 11
                }
            ],
            "animData": [
                {
                    "origLen": 62,
                    "pathId": 1777933383194314179
                },
                {
                    "origLen": 84,
                    "pathId": 5778389867427532372
                }
            ],
            "pathId": 971079598895263260,
            "blockIdx": 10
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "いやぁ、すごいな！\n本当に『日本ダービー』に来たぞ！！",
            "enText": "Man, this is amazing! It really is \nthe Japan Derby!",
            "nextBlock": 12,
            "origClipLength": 80,
            "voiceIdx": 6,
            "choices": [
                {
                    "jpText": "え――",
                    "enText": "Eh——",
                    "nextBlock": 12
                }
            ],
            "animData": [
                {
                    "origLen": 60,
                    "pathId": 4651158863610941702
                },
                {
                    "origLen": 91,
                    "pathId": -7314057604455187313
                }
            ],
            "pathId": -8001925673743463296,
            "blockIdx": 11
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "世代の頂点を競う、至高の舞台……！\n誰もが憧れ、鎬を削り目指す栄光……！",
            "enText": "A stage showcasing the greatest of the \ngeneration, an apex-level competition…! \nRacing to capture everyone's admiration, \nit's a ruthless battle for supreme glory…!",
            "nextBlock": 13,
            "origClipLength": 91,
            "voiceIdx": 7,
            "animData": [
                {
                    "origLen": 109,
                    "pathId": -5263133619035700031
                },
                {
                    "origLen": 102,
                    "pathId": 1825268027875057733
                }
            ],
            "pathId": 4929608671334082435,
            "blockIdx": 12
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "ハハッ……！　この私が……！\nダービーウマ娘を競う、ひと握りに……！",
            "enText": "<i>Hahah…!</i> I've made it…! I'm competing \nas a Derby horsegirl, this chance is in \nthe palm of my hands…!",
            "nextBlock": 14,
            "origClipLength": 89,
            "voiceIdx": 74,
            "coloredText": [
                {
                    "jpText": "ダービーウマ娘",
                    "enText": "Derby horsegirl"
                }
            ],
            "animData": [
                {
                    "origLen": 73,
                    "pathId": 5276535720449730206
                },
                {
                    "origLen": 100,
                    "pathId": 2314786670175634415
                }
            ],
            "pathId": 3641540878912282510,
            "blockIdx": 13
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "夢みたいだ……！！",
            "enText": "It's as if this is a dream…!!",
            "nextBlock": 15,
            "origClipLength": 56,
            "voiceIdx": -1,
            "choices": [
                {
                    "jpText": "ステゴ……――",
                    "enText": "Stego…",
                    "nextBlock": 15
                }
            ],
            "animData": [
                {
                    "origLen": 60,
                    "pathId": 3295776380293310189
                },
                {
                    "origLen": 67,
                    "pathId": -292869466990820985
                }
            ],
            "pathId": -2951133145031566478,
            "blockIdx": 14
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "……自分は、心のどこかでまだ、\nステイゴールドのことを\n誤解していたのかもしれない。",
            "enText": "…I feel as if some part of my heart \nhas misunderstood Stay Gold.",
            "nextBlock": 16,
            "origClipLength": 99,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 112,
                    "pathId": 8344930987203670069
                },
                {
                    "origLen": 110,
                    "pathId": -5701090528432515588
                }
            ],
            "pathId": 1268827045531765671,
            "blockIdx": 15
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "彼女は出会った時から超然としていて、\nその“記憶”故に、神秘的にすら感じていた。",
            "enText": "Her attitude had always been aloof since \nour first meeting. Additionally, due to the \nnature of her memories, her existence had \nfelt almost enigmatic.",
            "nextBlock": 17,
            "origClipLength": 97,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 13,
                    "pathId": -3256157651148816558
                },
                {
                    "origLen": 13,
                    "pathId": -2160461269054741882
                },
                {
                    "origLen": 128,
                    "pathId": -5855939131636352332
                },
                {
                    "origLen": 124,
                    "pathId": -2423438900171749273
                }
            ],
            "pathId": -6365704481381732894,
            "blockIdx": 16
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "雲のように掴みどころなく、\nいつだって自由気ままな彼女は、\n今更、感情で揺れ動くことなどないのだと――",
            "enText": "Her attitude as distant as the clouds she \nwatched in the sky, until now, I thought \nour free-spirited girl's emotions never \nwavered but ——",
            "nextBlock": 18,
            "origClipLength": 111,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 128,
                    "pathId": -1960883646028325503
                },
                {
                    "origLen": 124,
                    "pathId": 8134925094947056751
                }
            ],
            "pathId": 8036917191011982079,
            "blockIdx": 17
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "けれど、そうではない。\n今日については、そんなはずがない。",
            "enText": "This was not the case at all. Seeing \nher today confirmed this.",
            "nextBlock": 19,
            "origClipLength": 82,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 13,
                    "pathId": -414028558246344457
                },
                {
                    "origLen": 13,
                    "pathId": 565770437692132331
                }
            ],
            "pathId": 459200592800821693,
            "blockIdx": 18
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "彼女は自分よりもはるかに、\n実感をともなって、知っているのだ。",
            "enText": "She surpasses anything I could \never do, with insight far beyond \nmy comprehension.",
            "nextBlock": 20,
            "origClipLength": 85,
            "voiceIdx": -1,
            "pathId": 6873065621547984866,
            "blockIdx": 19
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "クラシックレースを目指すことの、難しさを。\n走れなかったことへの、悔しさを。\n走ることへの、憧れを。",
            "enText": "Understanding just how hard the Classics \ncan be… the crushing regret of being \nunable to run… Despite the insatiable \nyearn for it all.",
            "nextBlock": 21,
            "origClipLength": 110,
            "voiceIdx": -1,
            "pathId": -1620421732950597330,
            "blockIdx": 20
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "『日本ダービー』は、全ての競走ウマ娘と、\nそれに関わる者が憧れる、ウマ娘の祭典。\n代わりのない、唯一無二の栄光のレース。",
            "enText": "All the competitors in the Japan Derby \nbecome horsegirls worthy of admiration. \nThere is no substitute, as this is the one \nand only race for glory.",
            "nextBlock": 22,
            "origClipLength": 123,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 154,
                    "pathId": 3897005372220147592
                },
                {
                    "origLen": 162,
                    "pathId": 8927554289570970903
                }
            ],
            "pathId": 8341630796638059877,
            "blockIdx": 21
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "だから彼女が、今日にたどり着いたことを\n心から喜ぶのは、当然だ。それなら――",
            "enText": "By being able to stand here today, the \njoy that's overflowing from her heart \nis only natural. If that's the case —",
            "nextBlock": 23,
            "origClipLength": 94,
            "voiceIdx": -1,
            "choices": [
                {
                    "jpText": "俺たち、やったな！たどり着いた！！",
                    "enText": "We did it! We've made it all the way here!",
                    "nextBlock": 23
                },
                {
                    "jpText": "私たち、やったね！たどり着いた！！",
                    "enText": "We did it! We've made it all the way here!",
                    "nextBlock": 23
                }
            ],
            "animData": [
                {
                    "origLen": 154,
                    "pathId": 3459862182417743404
                },
                {
                    "origLen": 105,
                    "pathId": 7337118655329842519
                }
            ],
            "pathId": 4561995288798476441,
            "blockIdx": 22
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "……自分も共に、喜ぼう。\nこの栄光の地に立った旅路を。",
            "enText": "……I will celebrate for the both of us, \nfor the journey that has brought us \nboth to this glorious destination.",
            "nextBlock": 24,
            "origClipLength": 80,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 86,
                    "pathId": 2150698452912121661
                },
                {
                    "origLen": 91,
                    "pathId": 7085007564354556680
                },
                {
                    "origLen": 91,
                    "pathId": -8917266467317560120
                }
            ],
            "pathId": 1572366328749417642,
            "blockIdx": 23
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "いやはや、あんたすごいよなぁ！\n有言実行で、大したもんだよ！",
            "enText": "Y'know, you're pretty amazing! Your \nactions spoke louder than your words, \nit's genuinely impressive!",
            "nextBlock": 25,
            "origClipLength": 84,
            "voiceIdx": 115,
            "choices": [
                {
                    "jpText": "ステゴもすごいよ！君は過去を超えた！",
                    "enText": "Stego is also the best! Go defeat your past!",
                    "nextBlock": 25
                },
                {
                    "jpText": "ステゴもすごいよ！貴方は過去を超えた！",
                    "enText": "Stego is also the best! Go defeat your past!",
                    "nextBlock": 25
                }
            ],
            "animData": [
                {
                    "origLen": 20,
                    "pathId": -2616046973300394415
                },
                {
                    "origLen": 60,
                    "pathId": -1372788401675928111
                },
                {
                    "origLen": 95,
                    "pathId": 8756480283661277508
                }
            ],
            "pathId": -1928084489393155264,
            "blockIdx": 24
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "はっはっは！\nお互い頑張ったなぁ！",
            "enText": "<i>Hahaha!</i> We both did our very best hey!",
            "nextBlock": 26,
            "origClipLength": 73,
            "voiceIdx": 1,
            "choices": [
                {
                    "jpText": "ああ、本当に頑張った！",
                    "enText": "Yeah, we really did our best!",
                    "nextBlock": 26
                },
                {
                    "jpText": "うん、本当に頑張った！",
                    "enText": "Yeah, we really did our best!",
                    "nextBlock": 26
                }
            ],
            "animData": [
                {
                    "origLen": 84,
                    "pathId": -2046660556866230917
                },
                {
                    "origLen": 84,
                    "pathId": 8425355924462348119
                }
            ],
            "pathId": 8365772958364467217,
            "blockIdx": 25
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "本当に――",
            "enText": "Seriously ——",
            "nextBlock": 27,
            "origClipLength": 51,
            "voiceIdx": 73,
            "animData": [
                {
                    "origLen": 62,
                    "pathId": 6400867367538955363
                },
                {
                    "origLen": 62,
                    "pathId": -1347719764727659335
                }
            ],
            "pathId": 2398926335268704478,
            "blockIdx": 26
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "――……この道を選んで、よかったよ。",
            "enText": "…I'm really glad, this was the path I chose.",
            "nextBlock": 28,
            "origClipLength": 68,
            "voiceIdx": -1,
            "choices": [
                {
                    "jpText": "――――",
                    "enText": "",
                    "nextBlock": 28
                }
            ],
            "animData": [
                {
                    "origLen": 60,
                    "pathId": -753036359854704440
                },
                {
                    "origLen": 79,
                    "pathId": -3656443416107265508
                }
            ],
            "pathId": -4466248694352282789,
            "blockIdx": 27
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "共に楽しもう。今生に一度のレースを。\nそんでもって――",
            "enText": "Let's enjoy this together. It's a \nonce in a lifetime race. Also —",
            "nextBlock": 29,
            "origClipLength": 80,
            "voiceIdx": 91,
            "animData": [
                {
                    "origLen": 50,
                    "pathId": 1942163596217188281
                },
                {
                    "origLen": 91,
                    "pathId": -6897829117641655431
                }
            ],
            "pathId": -8488532679912622515,
            "blockIdx": 28
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "土産はダービートレーナーの称号でいいかい？",
            "enText": "My souvenir for you will be a title naming \nyou as the Trainer of the Japan Derby \nwinner, sound good?",
            "nextBlock": 30,
            "origClipLength": 72,
            "voiceIdx": -1,
            "choices": [
                {
                    "jpText": "……楽しみにしてるよ",
                    "enText": "…I'm looking forward to that",
                    "nextBlock": 30
                }
            ],
            "animData": [
                {
                    "origLen": 83,
                    "pathId": -3656424184507575630
                },
                {
                    "origLen": 83,
                    "pathId": 2537444353571767596
