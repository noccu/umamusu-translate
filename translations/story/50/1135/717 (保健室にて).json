            "pathId": 5789223846475676911,
            "blockIdx": 3
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "ああ。おやすみ、トレーナー。",
            "enText": "Yeah, good night, Trainer",
            "nextBlock": 5,
            "origClipLength": 63,
            "voiceIdx": 37,
            "animData": [
                {
                    "origLen": 67,
                    "pathId": 4489764021071591983
