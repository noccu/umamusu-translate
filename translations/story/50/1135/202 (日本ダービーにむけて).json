            "jpText": "――――",
            "enText": "————",
            "nextBlock": 7,
            "origClipLength": 50,
            "voiceIdx": -1,
            "choices": [
                {
                    "jpText": "（なんか……ぼーっとしてる……？）",
                    "enText": "(She's… looking a bit absentminded…?)",
                    "nextBlock": 7
                }
