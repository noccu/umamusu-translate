            "voiceIdx": -1,
            "choices": [
                {
                    "jpText": "君はどうすれば、GⅠ8勝を成せると思う？",
                    "enText": "How would you get 8 G1 victories?",
                    "nextBlock": 41
                },
                {
                    "jpText": "貴方はどうすればGⅠ8勝を成せると思う？",
                    "enText": "How would you get 8 G1 victories?",
                    "nextBlock": 41
