                }
            ],
            "pathId": 6479415431481123328,
            "blockIdx": 40
        },
        {
            "jpName": "海外ウマ娘",
            "enName": "Overseas Uma Musume",
            "jpText": "Looks like... I'm gonna win again!\n（今回も――勝利は私のものだ！）",
            "enText": "Looks like... I'm gonna win again!",
            "nextBlock": 42,
            "origClipLength": 82,
            "voiceIdx": 24,
            "animData": [
                {
                    "origLen": 107,
                    "pathId": -5303391837910293614
