            "pathId": -8772250564250990923,
            "blockIdx": 14
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "……！　はいっ、よろしくお願いします！\r\nエルちゃんに、グラスちゃん……って、呼んでもいいですか！？",
            "enText": "Y-Yeah, nice to meet you too! So… is it okay \nif I call you Grass and El then?",
            "nextBlock": 16,
            "origClipLength": 257,
            "voiceIdx": 13,
            "animData": [
                {
                    "origLen": 55,
                    "pathId": 8100901335039807040
                },
                {
                    "origLen": 20,
                    "pathId": -3697942797590394307
                },
                {
                    "origLen": 300,
                    "pathId": 2564243220059759309
                },
                {
                    "origLen": 304,
                    "pathId": 4556655861505748496
                },
                {
                    "origLen": 310,
                    "pathId": -1506464197542537056
                }
