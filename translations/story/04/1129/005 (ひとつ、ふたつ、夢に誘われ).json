            "pathId": -6442432457064536446,
            "blockIdx": 15
        },
        {
            "jpName": "アーモンドアイ",
            "enName": "Almond Eye",
            "jpText": "――ほら、横になって！\n眠れないトレーナーと眠らせたいわたし――いざ勝負よ！",
            "enText": "――Come on, lay down! A trainer that can't sleep, \nand me that wants to get my trainer to sleep――Let's do this!",
            "nextBlock": 17,
            "origClipLength": 272,
            "voiceIdx": 14,
            "animData": [
