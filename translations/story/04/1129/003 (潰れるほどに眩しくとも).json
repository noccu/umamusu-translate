                    "origLen": 68,
                    "pathId": 2037684036994006988
                }
            ],
            "pathId": -6917832493708836027,
            "blockIdx": 52
        },
        {
            "jpName": "アーモンドアイ",
            "enName": "Almond Eye",
            "jpText": "昔から、そうなんです。勝つことが好きで――ジュニアクラブでも\nいろんな子たちに、何度も何度も勝負を挑んだりしてきたっけ。",
            "enText": "It's always been like that for me. I love winning \n――Against a bunch of the junior club girls, \nI remember challenging them so, so many times.",
            "nextBlock": 54,
            "origClipLength": 289,
            "voiceIdx": 32,
            "animData": [
