                    "origLen": 42,
                    "pathId": 518510391665881401
                }
            ],
            "pathId": -8829274073980381594,
            "blockIdx": 46
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "身を焼き尽くすほどの執念の日々が――本当に、実ってしまった。",
            "enText": "Those days spent toiling away had paid off.",
            "nextBlock": 48,
            "origClipLength": 84,
            "voiceIdx": -1,
            "pathId": -3155590972081459375,
            "blockIdx": 47
        },
        {
            "jpName": "アーモンドアイ",
            "enName": "Almond Eye",
            "jpText": "……随分、遠くまで付き合わせてしまいましたね。\nでも、おかげで勝てました！　本当に、ありがとうございます。",
            "enText": "……You ended up accompanying me quite far, didn't you? \nBut, thanks to that, I was able to win! Really, thank you very much.",
            "nextBlock": 49,
            "origClipLength": 371,
            "voiceIdx": 28,
            "choices": [
                {
                    "jpText": "君は……なぜそんなことができるんだ",
                    "enText": "How……were you able to keep going?",
                    "nextBlock": 49
                },
                {
                    "jpText": "貴方は……なぜそんなことができるの",
                    "enText": "How……were you able to keep going?",
                    "nextBlock": 49
                }
            ],
            "animData": [
                {
                    "origLen": 174,
                    "pathId": -2478580211999004551
                },
                {
                    "origLen": 60,
                    "pathId": -7089360061651447874
                }
            ],
            "pathId": -8113676094166000421,
            "blockIdx": 48
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "なぜ、一度負けた相手に勝つためだけに、厳しいトレーニングを\n重ね、海外へまで渡り――なぜ、そこまでできるのだろうか。",
            "enText": "Why, just to beat someone she lost to once, she underwent strenuous \ntraining and even traveled overseas――Why was she able to go so far?",
            "nextBlock": 50,
            "origClipLength": 120,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 174,
                    "pathId": 7292006612988426418
                },
                {
                    "origLen": 56,
                    "pathId": 7929130158218484076
                }
            ],
            "pathId": -7480890465646900755,
            "blockIdx": 49
        },
        {
            "jpName": "アーモンドアイ",
            "enName": "Almond Eye",
            "jpText": "……“なぜ”って――",
            "enText": "……\"Why\" you ask?",
            "nextBlock": 51,
            "origClipLength": 76,
            "voiceIdx": 29,
            "animData": [
                {
                    "origLen": 50,
                    "pathId": -3145287793604968791
                },
                {
                    "origLen": 20,
                    "pathId": 2027669765844854437
                }
            ],
            "pathId": 3525278670095464833,
            "blockIdx": 50
        },
        {
            "jpName": "アーモンドアイ",
            "enName": "Almond Eye",
            "jpText": "勝ちたいから、ですよ？",
            "enText": "It's because I want to win",
            "nextBlock": 52,
            "origClipLength": 75,
            "voiceIdx": 30,
            "choices": [
                {
                    "jpText": "……――それだけのために？",
                    "enText": "……――Just for that?",
                    "nextBlock": 52
                }
            ],
            "animData": [
                {
                    "origLen": 115,
                    "pathId": 1715686444358509928
                }
            ],
            "pathId": 1303516435506568803,
            "blockIdx": 51
        },
        {
            "jpName": "アーモンドアイ",
            "enName": "Almond Eye",
            "jpText": "だって勝てると、嬉しいじゃないですか！　すごく、すっごく！",
            "enText": "Because winning is something that makes me happy! Incredibly so!",
            "nextBlock": 53,
            "origClipLength": 161,
            "voiceIdx": 31,
            "animData": [
