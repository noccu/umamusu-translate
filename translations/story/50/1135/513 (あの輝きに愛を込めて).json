            "pathId": 8582030991131978884,
            "blockIdx": 7
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "土産にちょうどよさそうだ。入ってみるか。",
            "enText": "I think they'd have some good souvenirs, \nlet's check it out.",
            "nextBlock": 9,
            "origClipLength": 71,
            "voiceIdx": 5,
            "animData": [
                {
                    "origLen": 50,
                    "pathId": -4189622886445231277
                },
                {
                    "origLen": 82,
                    "pathId": 7374504573022886059
                }
