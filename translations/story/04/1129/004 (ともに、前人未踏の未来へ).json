                    "origLen": 24,
                    "pathId": 8899343488470923094
                }
            ],
            "pathId": -7898062354062375461,
            "blockIdx": 46
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "羽をはばたかせ……やがて、海を渡り始める。\nはばたくたびに力を取り戻すように、少しずつ、少しずつ――",
            "enText": "It spread its wings and flew out to the sea. \nFlapping its wings as if regaining strength, little by little——",
            "nextBlock": 48,
            "origClipLength": 110,
