            "pathId": -5992558799690599295,
            "blockIdx": 7
        },
        {
            "jpName": "マルゼンスキー",
            "enName": "Maruzensky",
            "jpText": "やん！　可愛い後輩ちゃんを騙すわけないじゃない！\r\nバッドがグッドになるのは本当に本当なんだから！",
            "enText": "Oh, you! There's no way I would do such a thing to my \ncute little junior! It's true that this place can help turn \nyour bad vibes into good ones!",
            "nextBlock": 9,
            "origClipLength": 233,
            "voiceIdx": 5,
            "animData": [
                {
                    "origLen": 105,
