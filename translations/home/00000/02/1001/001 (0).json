    "text": [
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "こんなにいっぱいウマ娘さんがいるなんて\r\n……今でも不思議な気持ちです。",
            "enText": "There are so many horsegirls here… \nIt still feels weird to me.",
            "nextBlock": 2,
            "voiceIdx": 0,
            "pathId": -8249525019251346763,
            "blockIdx": 1
        },
        {
            "jpName": "サイレンススズカ",
            "enName": "Silence Suzuka",
            "jpText": "スペちゃんの故郷には\r\n他にウマ娘がいなかったのよね？",
            "enText": "You were the only horsegirl living \nin your hometown, right?",
            "nextBlock": 3,
            "voiceIdx": 1,
            "pathId": 7775262373362791245,
            "blockIdx": 2
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "はい。だからちょっとだけ\r\n緊張しちゃう時もありますけど……。",
            "enText": "Right. That's probably why I get a little \nnervous around the others occasionally…",
            "nextBlock": 4,
            "voiceIdx": 2,
            "pathId": -6096045219620915861,
            "blockIdx": 3
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "友だちいっぱい作るって\r\nお母ちゃんと約束したからがんばります！",
            "enText": "But I made a promise to my mom, so I've \ngotta make lots and lots of friends here!",
            "nextBlock": 5,
            "voiceIdx": 3,
            "pathId": 4831168724948785102,
            "blockIdx": 4
        },
        {
            "jpName": "サイレンススズカ",
            "enName": "Silence Suzuka",
            "jpText": "ふふっ。\r\nスペちゃんならきっとできるわ。",
            "enText": "Hehe, I'm sure you'll do just that.",
            "nextBlock": 6,
            "voiceIdx": 4,
            "pathId": -7852236419938035651,
            "blockIdx": 5
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "友だち100人出来たら、\r\nみんなでピクニックに行きたいな～♪",
            "enText": "Once I make a hundred friends, I wanna \nhave a huuuge picnic with everyone!♪",
            "nextBlock": 7,
            "voiceIdx": 5,
            "pathId": 1303449551262423733,
            "blockIdx": 6
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "その時は、\r\nにんじんサンド一緒に食べましょうね！",
            "enText": "When that happens, let's eat lots \nand lots of carrot sandwiches!",
            "nextBlock": 8,
            "voiceIdx": 6,
            "pathId": -8918331657237864044,
            "blockIdx": 7
        },
        {
            "jpName": "サイレンススズカ",
            "enName": "Silence Suzuka",
            "jpText": "ええ、楽しみにしているわ。",
            "enText": "Okay, I can't wait.",
            "nextBlock": -1,
            "voiceIdx": 7,
            "pathId": -3175477969629554243,
            "blockIdx": 8
        }
