            "pathId": -691102643064206721,
            "blockIdx": 23
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "キノコ料理……美味そうだなあ！\n……なあ！　私も食いにいっていいか！？",
            "enText": "Mushroom feast… That sounds so good! \n<i>…Hey!</i> Could you let me have a \ntaste too!?",
            "nextBlock": 25,
            "origClipLength": 90,
            "voiceIdx": 7,
            "choices": [
                {
                    "jpText": "え！急すぎない！？",
                    "enText": "Eh! This suddenly!?",
                    "nextBlock": 25
