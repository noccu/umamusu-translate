            "pathId": 910910374877747188,
            "blockIdx": 29
        },
        {
            "jpName": "ビューティー安心沢",
            "enName": "Beauty Anshinzawa",
            "jpText": "それじゃ、最後は――",
            "enText": "Now, last but not least…",
            "nextBlock": 31,
            "origClipLength": 87,
            "voiceIdx": 27,
            "animData": [
                {
                    "origLen": 102,
                    "pathId": 1718040934321163140
