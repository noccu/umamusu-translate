            "pathId": 2880709174512835625,
            "blockIdx": 35
        },
        {
            "jpName": "アーモンドアイ",
            "enName": "Almond Eye",
            "jpText": "もちろん！\n完璧に仕上げて、完璧に――貴方に勝ってみせます！",
            "enText": "Of course! \nMy preparations are perfect, perfect――for winning against you!",
            "nextBlock": 37,
            "origClipLength": 231,
