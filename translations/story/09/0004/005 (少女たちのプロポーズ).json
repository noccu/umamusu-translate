            "voiceIdx": 0,
            "pathId": 3815099304654660920,
            "blockIdx": 1
        },
        {
            "jpName": "エアグルーヴ",
            "enName": "Air Groove",
            "jpText": "ふん、なかなかやるな！",
            "enText": "Hmph! You're not half bad!",
            "nextBlock": 3,
            "origClipLength": 85,
            "voiceIdx": 1,
            "pathId": -6786535641877213766,
            "blockIdx": 2
        },
        {
            "jpName": "メジロドーベル",
            "enName": "Mejiro Dober",
            "jpText": "そちらこそ！\r\nけど、次の足場は譲りませんから……っ！",
            "enText": "I could say the same thing! I'm not giving up \nthe next foothold to you, though!",
            "nextBlock": 4,
            "origClipLength": 143,
            "voiceIdx": 2,
            "pathId": -4914090941968448239,
            "blockIdx": 3
        },
        {
            "jpName": "カワカミプリンセス",
            "enName": "Kawakami Princess",
            "jpText": "私のことを忘れてもらっては困りますわ！！\r\n――どっせぇえええええい！！",
            "enText": "Don't you two dare forget about me! LET'S GOOO!",
            "nextBlock": 5,
            "origClipLength": 185,
            "voiceIdx": 3,
            "pathId": 1417250485954828401,
            "blockIdx": 4
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "ゴールである教会を目指し、\r\n彼女たちは一心不乱に崖を登り続ける。",
            "enText": "The three horsegirls throw themselves into ascending \nthe cliff, their sights set on the chapel.",
            "nextBlock": 6,
            "origClipLength": 88,
            "voiceIdx": -1,
            "pathId": 1887193963692045815,
            "blockIdx": 5
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "全ては、己の想いを示すため――",
            "enText": "All for the sake of proving their passion…",
            "nextBlock": 7,
            "origClipLength": 64,
            "voiceIdx": -1,
            "pathId": 8281614460762056331,
            "blockIdx": 6
        },
        {
            "jpName": "エアグルーヴ",
            "enName": "Air Groove",
            "jpText": "（私の想いが見えぬというなら、今ここで見せてやる……！）",
            "enText": "(I'm lacking oomph, huh? I'll show you oomph…!)",
            "nextBlock": 8,
            "origClipLength": 139,
            "voiceIdx": 4,
            "pathId": -3589074305225758018,
            "blockIdx": 7
        },
        {
            "jpName": "ビューティー安心沢",
            "enName": "Beauty Anshinzawa",
            "jpText": "ワォワォワーォ！\r\nカワイイ足音が聞こえたかと思ったら、原石ちゃんが3人も～♪",
            "enText": "Wow, wow, wooow! Just when I thought I heard the \npitter-patter of pretty little footsteps, three lovely \ngems show up at my doorstep!♪",
            "nextBlock": 9,
            "origClipLength": 250,
            "voiceIdx": 5,
            "animData": [
