        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "寝すぎて……頭、痛い……。",
            "enText": "I… slept too much and… My head… \nIt hurts…",
            "nextBlock": 4,
            "origClipLength": 61,
            "voiceIdx": -1,
            "choices": [
                {
                    "jpText": "ええぇ……",
                    "enText": "Ehhh…",
