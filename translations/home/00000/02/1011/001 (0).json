    "text": [
        {
            "jpName": "エルコンドルパサー",
            "enName": "El Condor Pasa",
            "jpText": "ガーッデム！\n宿題があること忘れてました～っ！",
            "enText": "Gagh, dang! I forgot all about our homework!",
            "nextBlock": 2,
            "voiceIdx": 0,
            "pathId": 696257716767894383,
            "blockIdx": 1
        },
        {
            "jpName": "グラスワンダー",
            "enName": "Grass Wonder",
            "jpText": "あらあら～。大丈夫ですか？",
            "enText": "Oh my, is everything all right?",
            "nextBlock": 3,
            "voiceIdx": 1,
            "pathId": 644897792891568958,
            "blockIdx": 2
        },
        {
            "jpName": "エルコンドルパサー",
            "enName": "El Condor Pasa",
            "jpText": "――かくなる上はイチかバチかっ！\nグラァスお願――",
            "enText": "This is it… It's do or die! \nGrass, I need a favor ——",
            "nextBlock": 4,
            "voiceIdx": 2,
            "pathId": 7484995820218938774,
            "blockIdx": 3
        },
        {
            "jpName": "グラスワンダー",
            "enName": "Grass Wonder",
            "jpText": "写すのはナシですよ～、エル？",
            "enText": "You know I can't let you \ncopy my homework, El…",
            "nextBlock": 5,
            "voiceIdx": 3,
            "pathId": -2912709681074155941,
            "blockIdx": 4
        },
        {
            "jpName": "エルコンドルパサー",
            "enName": "El Condor Pasa",
            "jpText": "んぬぅ！？",
            "enText": "Nngh?!",
            "nextBlock": 6,
            "voiceIdx": 4,
            "pathId": 388486521255936045,
            "blockIdx": 5
        },
        {
            "jpName": "グラスワンダー",
            "enName": "Grass Wonder",
            "jpText": "宿題は自分で\n解かなきゃ意味がないですから～。",
            "enText": "There's no point to homework \nif you don't do it yourself…",
            "nextBlock": 7,
            "voiceIdx": 5,
            "pathId": -6996436724315135057,
            "blockIdx": 6
        },
        {
            "jpName": "グラスワンダー",
            "enName": "Grass Wonder",
            "jpText": "あなたもやればできるんですから、\r\nとりあえずやってみましょう！",
            "enText": "I'm sure you can do it if you try. \nI'll be cheering you on!",
            "nextBlock": 8,
            "voiceIdx": 6,
            "pathId": 7891920313008498255,
            "blockIdx": 7
        },
        {
            "jpName": "エルコンドルパサー",
            "enName": "El Condor Pasa",
            "jpText": "よ、読まれるとは……！",
            "enText": "H-How did you know…",
            "nextBlock": -1,
            "voiceIdx": 7,
