    "text": [
        {
            "jpName": "ウオッカ",
            "enName": "Vodka",
            "jpText": "オペラオー先輩！　ゴール後の\r\n決め台詞考えたんで見てください！",
            "enText": "Opera O! I thought of a cool one-liner! \nCouldja give it a listen for me?!",
            "nextBlock": 2,
            "voiceIdx": 0,
            "pathId": 197706100943076413,
            "blockIdx": 1
        },
        {
            "jpName": "ウオッカ",
            "enName": "Vodka",
            "jpText": "昨日寝ずに考えた自信作なんで！",
            "enText": "I spent all night thinking it up, \nso I'm sure it's a masterpiece!",
            "nextBlock": 3,
            "voiceIdx": 1,
            "pathId": -5026582445173415934,
            "blockIdx": 2
        },
        {
            "jpName": "テイエムオペラオー",
            "enName": "T.M. Opera O",
            "jpText": "はーっはっはっはっは！　いいだろう！\n君のアビスを、\nボクの前にさらけ出すといい……！",
            "enText": "Haaa-ha-ha-ha-ha! All right, show me \nthe depth of your abyss!",
            "nextBlock": 4,
            "voiceIdx": 2,
            "pathId": -8814865527917022570,
            "blockIdx": 3
        },
        {
            "jpName": "ウオッカ",
            "enName": "Vodka",
            "jpText": "――『俺はレースのアルティメット超新星。\r\nトリガーは引いたぜ。……パァン！』",
            "enText": "I am the Ultimate Supernova of \nthe Racecourse! Pull my trigger \nand watch me fly… Bam!",
            "nextBlock": 5,
            "voiceIdx": 3,
            "pathId": -7001724994028606278,
            "blockIdx": 4
        },
        {
            "jpName": "テイエムオペラオー",
            "enName": "T.M. Opera O",
            "jpText": "なるほど……！　悪くないね！",
            "enText": "Well, well, well! Not bad!",
            "nextBlock": 6,
            "voiceIdx": 4,
            "pathId": 7080478117929698163,
            "blockIdx": 5
        },
        {
            "jpName": "ウオッカ",
            "enName": "Vodka",
            "jpText": "ほんとっすか！？",
            "enText": "Really?! Truly?!",
            "nextBlock": 7,
            "voiceIdx": 5,
            "pathId": 1767020096938121559,
            "blockIdx": 6
        },
        {
            "jpName": "テイエムオペラオー",
            "enName": "T.M. Opera O",
            "jpText": "君のラジカルなナイトメアが感じられたよ。\r\n発砲とともにノクターンが聴こえてきそうだ。",
            "enText": "I could feel the radical nature of your \nnightmare. The rich vibrations of your \nsupernova echoed endlessly into the night!",
            "nextBlock": 8,
            "voiceIdx": 6,
            "pathId": 7841340762815407755,
            "blockIdx": 7
        },
        {
            "jpName": "ウオッカ",
            "enName": "Vodka",
            "jpText": "くっっそ、カッケェェ！！",
            "enText": "Ohhh… How'd you make it even cooler?!",
