            "pathId": -4991366609579447177,
            "blockIdx": 37
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "トリプルティアラ、海外GⅠ制覇、世界レコード、あるいは――！",
            "enText": "The Triple Tiara, Overseas G1 victory, World Records, or even——!",
            "nextBlock": 39,
