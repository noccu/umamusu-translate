{
    "version": 6,
    "bundle": "7BFC2VQ7D7RCOG3WXWZYDEJBHBIUYN6O",
    "type": "story",
    "storyId": "090001001",
    "title": "『はじめまして！』",
    "enTitle": "Nice to Meet You!",
    "text": [
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "つ……着いちゃった。\r\nとうとう、着いちゃった……！",
            "enText": "Ah… I made it. I finally arrived!",
            "nextBlock": 2,
            "origClipLength": 175,
            "voiceIdx": 0,
            "animData": [
                {
                    "origLen": 237,
                    "pathId": -1175840034924102963
                }
            ],
            "pathId": -5329239583542092241,
            "blockIdx": 1
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "ここが……東京……！",
            "enText": "I'm in… Tokyo!",
            "nextBlock": 3,
            "origClipLength": 105,
            "voiceIdx": 1,
            "animData": [
                {
                    "origLen": 45,
                    "pathId": -959325831836521527
                },
                {
                    "origLen": 67,
                    "pathId": 6409705827171403211
                }
            ],
            "pathId": 7806464005825968022,
            "blockIdx": 2
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "……って、いけない！　ボーっとしてる場合じゃないんだった！\r\nえっと、空港に着いたら、まずは……！",
            "enText": "…Wait, stay on track! This isn't the time for dawdling! \nLet's see… now that I'm at the airport, I have to…",
            "nextBlock": 4,
            "origClipLength": 208,
            "voiceIdx": 2,
            "animData": [
                {
                    "origLen": 50,
                    "pathId": 3258036837221377786
                },
                {
                    "origLen": 79,
                    "pathId": 2111935248435679889
                },
                {
                    "origLen": 36,
                    "pathId": 4879005745406245497
                }
            ],
            "pathId": 1898274192633788780,
            "blockIdx": 3
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "あのっ、すみません！！\r\n道を聞きたいんですが、大丈夫ですか！？",
            "enText": "Um, excuse me? Could you help me please? \nI need some directions.",
            "nextBlock": 5,
            "origClipLength": 129,
            "voiceIdx": 3,
            "animData": [
                {
                    "origLen": 55,
                    "pathId": -5220425991074399386
                },
                {
                    "origLen": 250,
                    "pathId": -1344837209073124045
                }
            ],
            "pathId": 2652717120846525270,
            "blockIdx": 4
        },
        {
            "jpName": "空港係員",
            "enName": "Airport Staff",
            "jpText": "はい、目的地はどちらでしょう？",
            "enText": "Yes, of course! Where are you trying to go?",
            "nextBlock": 6,
            "origClipLength": 88,
            "voiceIdx": 4,
            "animData": [
                {
                    "origLen": 107,
                    "pathId": 4670527072324509933
                },
                {
                    "origLen": 250,
                    "pathId": 885026822529655844
                }
            ],
            "pathId": -8250571588467719539,
            "blockIdx": 5
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "『日本ウマ娘トレーニングセンター学園』まで、お願いします！！",
            "enText": "I'm trying to get to the Japan Horsegirl \nTraining Center Academy, please!",
            "nextBlock": 7,
            "origClipLength": 136,
            "voiceIdx": 5,
            "animData": [
                {
                    "origLen": 36,
                    "pathId": 3893615119345470638
                },
                {
                    "origLen": 203,
                    "pathId": 8018431873794141392
                }
            ],
            "pathId": 2042286435898328404,
            "blockIdx": 6
        },
        {
            "jpName": "",
            "enName": "",
            "jpText": "タイトルコール",
            "enText": "",
            "nextBlock": 8,
            "origClipLength": 129,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 25,
                    "pathId": 3150010699492345179
                },
                {
                    "origLen": 25,
                    "pathId": -321730802678142591
                }
            ],
            "pathId": -2001904047461487303,
            "blockIdx": 7
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "レースの世界を目指す子たちにとって1番の憧れ――\r\n『日本最高峰のウマ娘養成機関』トレセン学園。",
            "enText": "Tracen Academy: Japan's best training institution \nfor horsegirls who aspire to enter the racing world.",
            "nextBlock": 9,
            "origClipLength": 276,
            "voiceIdx": 6,
            "pathId": -1989200814042766582,
            "blockIdx": 8
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "私だって、ずっと小さな頃からテレビで見てきた。\r\nトレセン学園のウマ娘さんたちが、ターフの上で輝くところ……。",
            "enText": "I've always admired the Tracen Academy racers. \nEver since I was little, I've watched them light up \nthe track on TV…",
            "nextBlock": 10,
            "origClipLength": 284,
            "voiceIdx": 7,
            "pathId": -6321212465129766267,
            "blockIdx": 9
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "みんな、みんな……立派で、キラキラしてて。\r\nすごいなぁって、いっぱい憧れた……！",
            "enText": "Each and every one of them was so special! \nThey really sparkled! I always wanted to be just like them…!",
            "nextBlock": 11,
            "origClipLength": 247,
            "voiceIdx": 8,
            "pathId": 6746127057599714803,
            "blockIdx": 10
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "（転入試験、受かったって聞いた時はびっくりして、\r\nお母ちゃんとほっぺた引っ張り合っちゃったけど！）",
            "enText": "(So I couldn't believe it when I passed the school \nentrance exam. Mom and I had to pinch each other \nto make sure we weren't dreaming!)",
            "nextBlock": 12,
            "origClipLength": 216,
            "voiceIdx": 9,
            "animData": [
                {
                    "origLen": 267,
                    "pathId": -6943532031998481967
                },
                {
                    "origLen": 20,
                    "pathId": 7884327121597373344
                }
            ],
            "pathId": -2985010541927730428,
            "blockIdx": 11
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "（夢じゃない……ううん、夢をほんとにするために、\r\n私、これから走るんだ……！）",
            "enText": "(But this is no dream. No, I'm here to make \nmy dreams come true! That's why… I have to run!)",
            "nextBlock": 13,
            "origClipLength": 253,
            "voiceIdx": 10,
            "animData": [
                {
                    "origLen": 80,
                    "pathId": 1009223389900333167
                },
                {
                    "origLen": 21,
                    "pathId": -5139146394247254049
                }
            ],
            "pathId": 5899659760842161199,
            "blockIdx": 12
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "――着いたっ！　学園最寄り駅……！　お母ちゃんからは、\r\nここで学園までの道をしっかり聞きなさいって言われたけど……。",
            "enText": "—— I'm here! This is the station closest to the academy! \nMom told me to make sure to ask someone for directions, but…",
            "nextBlock": 14,
            "origClipLength": 281,
            "voiceIdx": 11,
            "animData": [
                {
                    "origLen": 235,
                    "pathId": 8482797750699910654
                },
                {
                    "origLen": 143,
                    "pathId": 4568749781811825426
                }
            ],
            "pathId": -8672520596775637092,
            "blockIdx": 13
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "……ううん！　地図もちゃーんとあるんだし、大丈夫だよね！\r\nだって――",
            "enText": "…Nah! I have a map and everything. \nI'll be fine! After all…",
            "nextBlock": 15,
            "origClipLength": 175,
            "voiceIdx": 12,
            "animData": [
                {
                    "origLen": 78,
                    "pathId": 500233675000144041
                },
                {
                    "origLen": 20,
                    "pathId": 6008259400323305562
                }
            ],
            "pathId": 616600147394837086,
            "blockIdx": 14
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "私も、今日から『トレセン学園生』なんだし！！",
            "enText": "From today on, I'm a student of Tracen Academy!!",
            "nextBlock": 16,
            "origClipLength": 110,
            "voiceIdx": 13,
            "animData": [
                {
                    "origLen": 60,
                    "pathId": -1787037191614622845
                }
            ],
            "pathId": -5929518245872657109,
            "blockIdx": 15
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "……って調子乗ってた私のバカバカバカ、バカぁ～！！",
            "enText": "…A student with no sense of direction! \nDummy, dummy, dummy, dummyyy!!",
            "nextBlock": 17,
            "origClipLength": 174,
            "voiceIdx": 14,
            "animData": [
                {
                    "origLen": 43,
                    "pathId": 512166077789900959
                },
                {
                    "origLen": 87,
                    "pathId": 1613581798001259146
                }
            ],
            "pathId": 9003574111659823851,
            "blockIdx": 16
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "ここ、どこだべぇ～！",
            "enText": "Where in blazes am I?!",
            "nextBlock": 18,
            "origClipLength": 91,
            "voiceIdx": 15,
            "animData": [
                {
                    "origLen": 69,
                    "pathId": 2247187960511637808
                },
                {
                    "origLen": 130,
                    "pathId": -848525174286085018
                },
                {
                    "origLen": 52,
                    "pathId": 6076444220341765597
                }
            ],
            "pathId": -7390532794285296909,
            "blockIdx": 17
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "うぅ……日が傾いてきちゃったし、お腹も空いたし……\r\n私、このまま遭難しちゃうのかなぁ……！？　お母ちゃぁ～ん……！",
            "enText": "Uh-oh… The sun's getting low… and I'm hungry too. \nAm I on a one-way road to disaster? Mooooom…!",
            "nextBlock": 19,
            "origClipLength": 390,
            "voiceIdx": 16,
            "animData": [
                {
                    "origLen": 70,
                    "pathId": 7684540993440084499
                },
                {
                    "origLen": 93,
                    "pathId": 7094049299290673327
                }
            ],
            "pathId": 3414754778907166125,
            "blockIdx": 18
        },
        {
            "jpName": "",
            "enName": "",
            "jpText": "（ザッ――……！！）",
            "enText": "(<i>Whoosh…!!</i>)",
            "nextBlock": 20,
            "origClipLength": 58,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 85,
                    "pathId": 7710526566652401387
                },
                {
                    "origLen": 52,
                    "pathId": -7276979781215104827
                }
            ],
            "pathId": -8515288745640259902,
            "blockIdx": 19
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "っ、……へ？　風……？",
            "enText": "……Huh? Was that the wind…?",
            "nextBlock": 21,
            "origClipLength": 95,
            "voiceIdx": 17,
            "animData": [
                {
                    "origLen": 127,
                    "pathId": -4598281051317692939
                }
            ],
            "pathId": 3540587674557488626,
            "blockIdx": 20
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "（――じゃ、ない！　今のって……！！）",
            "enText": "(Not a chance! That was totally…!!)",
            "nextBlock": 22,
            "origClipLength": 81,
            "voiceIdx": 18,
            "animData": [
                {
                    "origLen": 165,
                    "pathId": -3803256788250491296
                },
                {
                    "origLen": 251,
                    "pathId": 6191982663652705868
                }
            ],
            "pathId": -6833962592398653649,
            "blockIdx": 21
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "耳と、尻尾……私とおんなじ――！",
            "enText": "Those ears, that tail… They're just like mine!",
            "nextBlock": 23,
            "origClipLength": 142,
            "voiceIdx": 19,
            "animData": [
                {
                    "origLen": 89,
                    "pathId": 2049216238137617859
                },
                {
                    "origLen": 251,
                    "pathId": 1653287063866544875
                }
            ],
            "pathId": -5653738836484224572,
            "blockIdx": 22
        },
        {
            "jpName": "サイレンススズカ",
            "enName": "Silence Suzuka",
            "jpText": "……？",
            "enText": "……?",
            "nextBlock": 24,
            "origClipLength": 31,
            "voiceIdx": 20,
            "animData": [
                {
                    "origLen": 11,
                    "pathId": -8125488185408812869
                },
                {
                    "origLen": 11,
                    "pathId": 3475906816819465106
                },
                {
                    "origLen": 99,
                    "pathId": -4340775701125827838
                },
                {
                    "origLen": 54,
                    "pathId": 3866455875597416401
                }
            ],
            "pathId": 7164718638884053271,
            "blockIdx": 23
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "うわぁ、うわぁ、うわぁあああああっ！\r\nほんとに、ほんとにほんとにっ――",
            "enText": "No way! Whoa, whoa, whoaaaa! \nYou're actually, like really, actually ——",
            "nextBlock": 25,
            "origClipLength": 188,
            "voiceIdx": 21,
            "animData": [
                {
                    "origLen": 129,
                    "pathId": -906582209352927194
                },
                {
                    "origLen": 170,
                    "pathId": -312225918632316132
                }
            ],
            "pathId": -1730040465188675052,
            "blockIdx": 24
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "ウマ娘さん、ですよねっ！？",
            "enText": "—— a horsegirl, aren't you?!",
            "nextBlock": 26,
            "origClipLength": 72,
            "voiceIdx": 22,
            "animData": [
                {
                    "origLen": 52,
                    "pathId": 188378073641326687
                },
                {
                    "origLen": 57,
                    "pathId": -4427815279056246920
                }
            ],
            "pathId": 1868516654839835588,
            "blockIdx": 25
        },
        {
            "jpName": "サイレンススズカ",
            "enName": "Silence Suzuka",
            "jpText": "えっ……？　え、ええ……。\r\nあの、何か……？",
            "enText": "H-Huh? I-I am, but… do you need something?",
            "nextBlock": 27,
            "origClipLength": 157,
            "voiceIdx": 23,
            "pathId": 4984727124340025981,
            "blockIdx": 26
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "いえっ！　ただ、直接見るの、初めてなので……！！",
            "enText": "No! I mean, this is just my first time \nseeing one in person like this…!!",
            "nextBlock": 28,
            "origClipLength": 124,
            "voiceIdx": 24,
            "pathId": 3361831915790181190,
            "blockIdx": 27
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "（うわぁ、うわぁぁぁ～……私と同じウマ娘さん、だけど全然違う！\r\n尻尾の毛並みが夕陽にキラキラ光って……きれ～……！）",
            "enText": "(Whoaaa, like… <i>Whoa!</i> This is crazy! She's a horsegirl \nlike me, yet so different! Her tail sparkling in the setting \nsun is so prettyyy…!!)",
            "nextBlock": 29,
            "origClipLength": 383,
            "voiceIdx": 25,
            "pathId": 1623618661696135839,
            "blockIdx": 28
        },
        {
            "jpName": "サイレンススズカ",
            "enName": "Silence Suzuka",
            "jpText": "…………えっと。",
            "enText": "Ummm…",
            "nextBlock": 30,
            "origClipLength": 51,
            "voiceIdx": 26,
            "pathId": 597064969165566593,
            "blockIdx": 29
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "って、わわぁ！！　すすすすみませんっ、じろじろ見ちゃって！\r\nきれいだな～って思って、つい～……あははは……！！",
            "enText": "Aaah! S-S-Sorry! I didn't mean to stare at you like that! \nI was just so amazed with how pretty you are… Ahahaha!",
            "nextBlock": 31,
            "origClipLength": 248,
            "voiceIdx": 27,
            "pathId": 227728530472957879,
            "blockIdx": 30
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "ん、あれっ？　よく見ると、その赤いジャージ……\r\nもしかして、トレセン学園の生徒さんですかっ！？",
            "enText": "Oh, now that I take a closer look, that red tracksuit of yours… \nDoes that mean you're a student at Tracen Academy?",
            "nextBlock": 32,
            "origClipLength": 257,
            "voiceIdx": 28,
            "animData": [
                {
                    "origLen": 80,
                    "pathId": -4186375532013247441
                },
                {
                    "origLen": 20,
                    "pathId": 3405019252065057341
                },
                {
                    "origLen": 172,
                    "pathId": -8509756600557759752
                }
            ],
            "pathId": -4300484971098200945,
            "blockIdx": 31
        },
        {
            "jpName": "サイレンススズカ",
            "enName": "Silence Suzuka",
            "jpText": "え、ええ。でも、その制服……あなたも、ですよね？",
            "enText": "Y-Yes… And your uniform means… you're one too, no?",
            "nextBlock": 33,
            "origClipLength": 205,
            "voiceIdx": 29,
            "animData": [
                {
                    "origLen": 288,
                    "pathId": 1627078575866575188
                },
                {
                    "origLen": 60,
                    "pathId": 3739201170305656012
                },
                {
                    "origLen": 20,
                    "pathId": 2153057875694051643
                }
            ],
            "pathId": 2279168494071692176,
            "blockIdx": 32
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "あっ、私は今日転入してきたばっかりなんです！！\r\nスペシャルウィークって言います、よろしくお願いします！！",
            "enText": "Ah, I just transferred here today though!!\nI'm Special Week! Nice to meet you!!",
            "nextBlock": 34,
            "origClipLength": 227,
            "voiceIdx": 30,
            "animData": [
                {
                    "origLen": 40,
                    "pathId": 7944567188781847595
                },
                {
                    "origLen": 362,
                    "pathId": 1152901219808437079
                }
            ],
            "pathId": -63133413126565215,
            "blockIdx": 33
        },
        {
            "jpName": "サイレンススズカ",
            "enName": "Silence Suzuka",
            "jpText": "そうなんですか……えっと、よろしくお願いします。\r\n私、サイレンススズカです。",
            "enText": "Is that right? …Um, nice to meet you too. I'm Silence Suzuka.",
            "nextBlock": 35,
            "origClipLength": 243,
            "voiceIdx": 31,
            "animData": [
                {
                    "origLen": 198,
                    "pathId": 8032190072619239952
                },
                {
                    "origLen": 160,
                    "pathId": -2936176386481450379
                },
                {
                    "origLen": 54,
                    "pathId": 7504287474152027132
                }
            ],
            "pathId": -683276319172960542,
            "blockIdx": 34
        },
        {
            "jpName": "スペシャルウィーク",
            "enName": "Special Week",
            "jpText": "スズカさん、ですね！　覚えましたっ。\r\nあの、それで……いっこ聞いてもいいですか……？",
            "enText": "Suzuka, huh? I won't forget! Anyway, um… is it okay \nif I ask you something?",
            "nextBlock": 36,
            "origClipLength": 259,
            "voiceIdx": 32,
            "animData": [
                {
                    "origLen": 40,
                    "pathId": 281338571188330918
                },
                {
                    "origLen": 20,
                    "pathId": 7332312109071320118
                },
                {
                    "origLen": 374,
                    "pathId": -5321419181339064594
                },
                {
                    "origLen": 271,
                    "pathId": 5214696761428049425
                }
            ],
            "pathId": 7496745724873858382,
            "blockIdx": 35
        },
        {
            "jpName": "サイレンススズカ",
            "enName": "Silence Suzuka",
            "jpText": "はい……？",
            "enText": "…Yes?",
            "nextBlock": 37,
            "origClipLength": 32,
            "voiceIdx": 33,
            "animData": [
                {
                    "origLen": 132,
                    "pathId": -4975846302841066904
                },
                {
                    "origLen": 327,
                    "pathId": -2383983585561112664
                },
                {
                    "origLen": 49,
                    "pathId": 4014415607132302005
                }
            ],
            "pathId": 8863303831274843875,
            "blockIdx": 36
        },
