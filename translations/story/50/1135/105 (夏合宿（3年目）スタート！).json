            "pathId": -5631558302465424240,
            "blockIdx": 3
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "……『天皇賞（秋）』の頃には、\nどんな空気になってるやら。",
            "enText": "",
            "nextBlock": 5,
            "origClipLength": 82,
            "voiceIdx": 80,
            "animData": [
                {
                    "origLen": 43,
                    "pathId": -1847689720560416898
