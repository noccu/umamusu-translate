            "pathId": 60609210175503966,
            "blockIdx": 30
        },
        {
            "jpName": "エアグルーヴ",
            "enName": "Air Groove",
            "jpText": "……。",
            "enText": "……",
            "nextBlock": 32,
            "origClipLength": 32,
            "voiceIdx": 28,
            "animData": [
                {
                    "origLen": 89,
                    "pathId": 2213405753828797546
                }
            ],
            "pathId": 216591032396619259,
            "blockIdx": 31
        },
        {
            "jpName": "幼いエアグルーヴ",
            "enName": "Young Air Groove",
            "jpText": "では私も、大きくなったらお母様のように\r\n一流デザイナーに勝負服を作ってもらいます！",
            "enText": "Then when I grow up, I'm going to be like you and get \na first-rate designer to create my very own racewear!",
            "nextBlock": 33,
            "origClipLength": 203,
            "voiceIdx": 29,
            "animData": [
                {
                    "origLen": 13,
                    "pathId": 7123391704910509802
                }
            ],
            "pathId": -3528419278500117688,
            "blockIdx": 32
        },
        {
            "jpName": "幼いエアグルーヴ",
            "enName": "Young Air Groove",
            "jpText": "お母様みたいな勝負服を着て、\r\nお母様みたいな綺麗でかっこいいウマ娘になります！",
            "enText": "I'll wear a racing costume like yours and become a beautiful \nand amazing horsegirl just like you, Mother!",
            "nextBlock": 34,
            "origClipLength": 203,
            "voiceIdx": 30,
            "pathId": -6051973882733420151,
            "blockIdx": 33
        },
        {
            "jpName": "エアグルーヴの母親",
            "enName": "Air Groove's Mother",
            "jpText": "嬉しいこと言ってくれるじゃないの～♪\r\nじゃあ、お母さんも全力で応援しなきゃね！",
            "enText": "It makes me so happy to hear you say that♪ \nIn that case, I have to cheer you on with all my might!",
            "nextBlock": 35,
            "origClipLength": 194,
            "voiceIdx": 31,
            "pathId": 8099432274378588742,
            "blockIdx": 34
        },
        {
            "jpName": "エアグルーヴ",
            "enName": "Air Groove",
            "jpText": "……私にとっての勝負服は、\r\n憧れであり、私が目指す姿の象徴でもあります。",
