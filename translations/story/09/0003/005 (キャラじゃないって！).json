    "title": "キャラじゃないって！",
    "enTitle": "Out of Character",
    "text": [
        {
            "jpName": "キタサンブラック",
            "enName": "Kitasan Black",
            "jpText": "みんなで取り組む奉仕活動にも慣れてきた、ある日のこと。\r\nあたしたちがやってきたのは……。",
            "enText": "The days go by as we continue our community service together. \nToday, we have a special task lined up…",
            "nextBlock": 2,
            "origClipLength": 215,
            "voiceIdx": 0,
            "pathId": 4689723260193405085,
            "blockIdx": 1
        },
        {
            "jpName": "子どものウマ娘A",
            "enName": "Child Horsegirl A",
            "jpText": "わぁ～っ、すごーい！\r\nおねえちゃん知ってる、いっぱい走ってるよね！",
            "enText": "Whoa, awesome! I know you! You're really good at running!",
            "nextBlock": 3,
            "origClipLength": 173,
            "voiceIdx": 1,
            "pathId": 1435063431480647928,
            "blockIdx": 2
        },
        {
            "jpName": "ナイスネイチャ",
            "enName": "Nice Nature",
            "jpText": "ええと、それはどうも……ありがとう、ございます？",
            "enText": "Ohh, you know me? Uhh… Thank you?",
            "nextBlock": 4,
            "origClipLength": 192,
            "voiceIdx": 2,
            "pathId": -4826638756104533099,
            "blockIdx": 3
        },
        {
            "jpName": "子どものウマ娘B",
            "enName": "Child Horsegirl B",
            "jpText": "すご～い、かみのけふわふわ！\r\nテレビで見るよりかわいいねぇ！",
            "enText": "Wow, your hair is so soft! You're even cuter than you look on TV!",
            "nextBlock": 5,
            "origClipLength": 213,
            "voiceIdx": 3,
            "pathId": 9085463042058009037,
            "blockIdx": 4
        },
        {
            "jpName": "ナイスネイチャ",
            "enName": "Nice Nature",
            "jpText": "えっ！？　か、かわ……！？",
            "enText": "Huh?! I-I'm cute?!",
            "nextBlock": 6,
            "origClipLength": 78,
            "voiceIdx": 4,
            "pathId": -357033076758827604,
            "blockIdx": 5
        },
        {
            "jpName": "子どものウマ娘B",
            "enName": "Child Horsegirl B",
            "jpText": "うん、とってもかわいい！\r\nおねえちゃん、だいすきー！",
            "enText": "Super cute! I looove you!",
            "nextBlock": 7,
            "origClipLength": 165,
            "voiceIdx": 5,
            "pathId": -2131948295254317955,
            "blockIdx": 6
        },
        {
            "jpName": "ナイスネイチャ",
            "enName": "Nice Nature",
            "jpText": "え、あ……や、そんな簡単に大好きとか……！\r\nちょ、タンホイザ助け――",
            "enText": "Er, um… You really shouldn't use that word so lightly… \nHey, Tannhauser! Help me ——",
            "nextBlock": 8,
            "origClipLength": 214,
            "voiceIdx": 6,
            "pathId": 2431929442556652402,
            "blockIdx": 7
        },
        {
            "jpName": "マチカネタンホイザ",
            "enName": "Matikanetannhauser",
            "jpText": "尻尾もふわふわでかわいいねぇ～！\r\nお耳もぴょこぴょこかわいいねぇ～。",
            "enText": "Her tail is so fluffy and soft, right? \nAnd just look at those cute little ears!",
            "nextBlock": 9,
            "origClipLength": 182,
            "voiceIdx": 7,
            "pathId": -5012336282893221408,
            "blockIdx": 8
        },
        {
            "jpName": "ナイスネイチャ",
            "enName": "Nice Nature",
            "jpText": "いや混ざるなっ！\r\nうぅ、なんでアタシがこんな目に……！",
            "enText": "No, don't encourage them! Ugh, why meee?",
            "nextBlock": 10,
            "origClipLength": 167,
            "voiceIdx": 8,
            "pathId": 4301835324384572555,
            "blockIdx": 9
        },
        {
            "jpName": "子どものウマ娘B",
            "enName": "Child Horsegirl B",
            "jpText": "おねえちゃん、おうた歌って！\r\nかわいいおうたききたーいっ！",
            "enText": "Hey, Nature! Sing something for us! We wanna hear a cute song!",
            "nextBlock": 11,
            "origClipLength": 168,
            "voiceIdx": 9,
            "pathId": 7886571318541263605,
            "blockIdx": 10
        },
        {
            "jpName": "ナイスネイチャ",
            "enName": "Nice Nature",
            "jpText": "うひゃあ！？　か、勘弁してーっっ！！",
            "enText": "Sing?! Come on, cut me some slack!",
            "nextBlock": 12,
            "origClipLength": 131,
            "voiceIdx": 10,
            "pathId": 7167902133617438380,
            "blockIdx": 11
        },
        {
            "jpName": "キタサンブラック",
            "enName": "Kitasan Black",
            "jpText": "というわけで！　今日は走ることが大好きなウマ娘のみんなに、\r\nちょっぴりお姉ちゃんのあたしたちが、走り方を教えるね！",
            "enText": "All right, everyone! Today, we're going to teach you little ones \na few things about how us big horsegirls run!",
            "nextBlock": 13,
            "origClipLength": 274,
            "voiceIdx": 11,
            "animData": [
                {
                    "origLen": 50,
                    "pathId": -1505839437616448394
