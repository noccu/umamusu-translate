                    "origLen": 328,
                    "pathId": -1740320741458478581
                }
            ],
            "pathId": 6665456615285892964,
            "blockIdx": 7
        },
        {
            "jpName": "アーモンドアイ",
            "enName": "Almond Eye",
            "jpText": "最後は特製の安眠粥よ。お米の『トリプトファン』と\n鶏の『ビタミンB6』が、睡眠を誘うホルモンの生成を促すの。",
            "enText": "And lastly, some porridge full of sleep-inducing \nvitamins. 『Tryptophan』 in the rice, and 『Vitamin B6』 in \nthe chicken help produce hormones that help with sleep.",
            "nextBlock": 9,
            "origClipLength": 294,
            "voiceIdx": 6,
            "animData": [
                {
                    "origLen": 385,
                    "pathId": -4686267582706781177
                },
                {
                    "origLen": 20,
                    "pathId": 693450557789086269
                },
                {
                    "origLen": 409,
