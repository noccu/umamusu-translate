            "pathId": 9105224766194801479,
            "blockIdx": 8
        },
        {
            "jpName": "エルコンドルパサー",
            "enName": "El Condor Pasa",
            "jpText": "ブエノーーー！！",
            "enText": "Bueno!",
            "nextBlock": 10,
            "origClipLength": 65,
            "voiceIdx": 7,
            "animData": [
                {
                    "origLen": 158,
                    "pathId": 3326203250182373006
                },
                {
                    "origLen": 99,
                    "pathId": 1037780128718462394
