            "pathId": -5763881514828201479,
            "blockIdx": 41
        },
        {
            "jpName": "アーモンドアイ",
            "enName": "Almond Eye",
            "jpText": "勝つ、勝つ、勝つ……っ、勝つ――ッ！！\nあああああぁあああああああああああああ――――！！",
            "enText": "Win, win, win……I will win――!! \nAaaaaaaaaaaaaaaaaaaaaaaaaaaahh――――!!",
            "nextBlock": 43,
            "origClipLength": 284,
