    "text": [
        {
            "jpName": "オグリキャップ",
            "enName": "Oguri Cap",
            "jpText": "故郷のトメさんたちは、\r\nいま頃どうしているのだろう。",
            "enText": "I wonder what Tome and the other folks \nfrom back home are doing right now…",
            "nextBlock": 2,
            "voiceIdx": 0,
            "pathId": -1216352084351065610,
            "blockIdx": 1
        },
        {
            "jpName": "オグリキャップ",
            "enName": "Oguri Cap",
            "jpText": "早くみんなに、\nいい報告を届けてあげたいな。",
            "enText": "It'd be nice if I could give them \nsome good news soon.",
            "nextBlock": 3,
            "voiceIdx": 1,
            "pathId": -2630812145797165352,
            "blockIdx": 2
        },
        {
            "jpName": "オグリキャップ",
            "enName": "Oguri Cap",
            "jpText": "……トレーナーは、\n故郷が恋しくなったりしないのか？",
            "enText": "…Trainer, do you ever miss your hometown?",
            "nextBlock": 4,
            "voiceIdx": 2,
            "pathId": 69063995103040143,
            "blockIdx": 3
        },
        {
            "jpName": "オグリキャップ",
            "enName": "Oguri Cap",
            "jpText": "もし寂しくなった時は、\r\n言ってくれ。",
            "enText": "If you do, please let me know.",
            "nextBlock": 5,
            "voiceIdx": 3,
            "pathId": -2128607325218925165,
            "blockIdx": 4
        },
        {
            "jpName": "オグリキャップ",
            "enName": "Oguri Cap",
            "jpText": "――私が、\nキミのトメさんになる！",
            "enText": "I will be your Tome!",
            "nextBlock": -1,
            "voiceIdx": 4,
            "pathId": 614347355566502572,
            "blockIdx": 5
        }
