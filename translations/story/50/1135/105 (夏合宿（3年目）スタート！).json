    "title": "夏合宿（3年目）スタート！",
    "enTitle": "",
    "text": [
        {
            "jpName": "",
            "enName": "",
            "jpText": "――――迎えた、シニア級での夏合宿。",
            "enText": "",
            "nextBlock": 2,
            "origClipLength": 68,
            "voiceIdx": -1,
            "pathId": -8276745865261026638,
            "blockIdx": 1
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "ふ～……\n涼しくていい感じだ……――",
            "enText": "",
            "nextBlock": 3,
            "origClipLength": 77,
            "voiceIdx": 59,
            "choices": [
                {
                    "jpText": "今日は少し日が落ちてから始めようか",
                    "enText": "",
                    "nextBlock": 3
                }
            ],
            "animData": [
                {
                    "origLen": 154,
