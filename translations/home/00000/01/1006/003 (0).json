            "pathId": -6356261218252752226,
            "blockIdx": 2
        },
        {
            "jpName": "オグリキャップ",
            "enName": "Oguri Cap",
            "jpText": "笠松にいた頃よりずっと、\n競い合うことが、楽しい。",
            "enText": "Racing everyone here is so much fun, \neven more fun than back in Kasamatsu.",
            "nextBlock": 4,
            "voiceIdx": 2,
            "pathId": -2171896110004328028,
            "blockIdx": 3
        },
        {
            "jpName": "オグリキャップ",
            "enName": "Oguri Cap",
            "jpText": "トレーナー、期待してくれ。\n私は……勝つぞ。",
