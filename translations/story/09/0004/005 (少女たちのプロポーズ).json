            "pathId": -4863732879603339876,
            "blockIdx": 15
        },
        {
            "jpName": "カワカミプリンセス",
            "enName": "Kawakami Princess",
            "jpText": "私にとって勝負服は、理想の自分……\r\n優雅で気高いプリンセスになるという誓いの証です。",
            "enText": "To me, racewear represents my ideal self… \nIt is the proof of my vow to become a princess \nwith both elegance and dignity.",
            "nextBlock": 17,
            "origClipLength": 318,
            "voiceIdx": 13,
            "animData": [
                {
                    "origLen": 14,
                    "pathId": -6630485975433922132
                },
                {
                    "origLen": 14,
                    "pathId": 4261412114039635738
                },
                {
                    "origLen": 119,
                    "pathId": 2305656404013289488
                },
                {
                    "origLen": 67,
                    "pathId": -3133138968145993739
                },
                {
                    "origLen": 11,
                    "pathId": 2432676785814241044
                },
                {
                    "origLen": 11,
                    "pathId": 9176213685164131189
                }
            ],
            "pathId": 8785060231657218102,
            "blockIdx": 16
        },
        {
            "jpName": "カワカミプリンセス",
            "enName": "Kawakami Princess",
            "jpText": "美しい衣装にふさわしい淑女になって、\r\nいつか王子様に見つけてもらえるよう――",
            "enText": "In order to become a lady worthy of exquisite attire and to be \ndiscovered by my very own Prince Charming one day…",
            "nextBlock": 18,
            "origClipLength": 208,
            "voiceIdx": 14,
            "animData": [
                {
                    "origLen": 157,
                    "pathId": -3659175796072328784
                },
                {
                    "origLen": 69,
                    "pathId": -5979338583974778949
                }
            ],
            "pathId": 5019224878996467606,
            "blockIdx": 17
        },
        {
            "jpName": "カワカミプリンセス",
            "enName": "Kawakami Princess",
            "jpText": "どんなにつらい道のりであろうとも、\r\n共に歩み続けることを誓いますわ！",
            "enText": "I vow to continue walking side by side with my racewear, \nno matter how challenging the path may be!",
            "nextBlock": 19,
            "origClipLength": 177,
            "voiceIdx": 15,
            "animData": [
                {
                    "origLen": 56,
                    "pathId": 6555050414404354411
                },
