                {
                    "origLen": 20,
                    "pathId": 6045935309164194758
                }
            ],
            "pathId": 2188037752514931566,
            "blockIdx": 35
        },
        {
            "jpName": "グラスワンダー",
            "enName": "Grass Wonder",
            "jpText": "しっかりしなさい、エル！\r\n幻術に振り回されてはダメ！",
            "enText": "Pull yourself together, El! Don't let those illusions sway you!",
            "nextBlock": 37,
