        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "（ピピピピピピ……――ピッ）",
            "enText": "(<i>Beep, beep, beep… Beep…</i>)",
            "nextBlock": 2,
            "origClipLength": 63,
