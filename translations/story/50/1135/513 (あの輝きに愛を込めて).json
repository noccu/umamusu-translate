                {
                    "origLen": 87,
                    "pathId": -3867496754723383381
                }
            ],
            "pathId": 7366699917379095947,
            "blockIdx": 6
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "おっ、この店。\n物珍しいのを置いてるな。",
            "enText": "Oh, this store's got some pretty \nmysterious items.",
            "nextBlock": 8,
            "origClipLength": 71,
            "voiceIdx": 30,
            "animData": [
                {
                    "origLen": 20,
                    "pathId": 2296074880630498329
                },
                {
                    "origLen": 52,
