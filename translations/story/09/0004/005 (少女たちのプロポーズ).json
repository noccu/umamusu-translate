            "pathId": -6997538721115384917,
            "blockIdx": 20
        },
        {
            "jpName": "メジロドーベル",
            "enName": "Mejiro Dober",
            "jpText": "は、はい……！",
            "enText": "Y-Yes, ma'am…!",
            "nextBlock": 22,
            "origClipLength": 72,
