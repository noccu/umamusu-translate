            "pathId": 3482530374735224996,
            "blockIdx": 45
        },
        {
            "jpName": "アーモンドアイ",
            "enName": "Almond Eye",
            "jpText": "まだまだっ、まだまだ、……っ、まだまだ！！！\nまだまだっ、ここからぁああーーーーーーッ！！",
            "enText": "Not yet not yet, not yet not yet……Not yet not yet!!! \nNot yet, right heeeeerreーーーーーー!!",
            "nextBlock": 47,
