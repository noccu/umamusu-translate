            "pathId": 822648276587277712,
            "blockIdx": 11
        },
        {
            "jpName": "アーモンドアイ",
            "enName": "Almond Eye",
            "jpText": "……絶っ対に嫌！！",
            "enText": "……I absolutely refuse!!",
            "nextBlock": 13,
            "origClipLength": 132,
            "voiceIdx": 10,
            "animData": [
                {
