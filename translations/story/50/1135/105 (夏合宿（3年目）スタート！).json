            ],
            "pathId": -5156513791606260910,
            "blockIdx": 9
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "ただ、これだけは言えるよ。\n集まった方が面白そうだってな。",
            "enText": "",
            "nextBlock": 11,
            "origClipLength": 82,
            "voiceIdx": 86,
            "animData": [
                {
                    "origLen": 55,
