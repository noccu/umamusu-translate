            "pathId": 3953440136975239816,
            "blockIdx": 34
        },
        {
            "jpName": "アーモンドアイ",
            "enName": "Almond Eye",
            "jpText": "貴方が、わたしのトレーナーになってくれない？",
            "enText": "Will you become my trainer?",
            "nextBlock": 36,
            "origClipLength": 118,
            "voiceIdx": 15,
            "choices": [
                {
                    "jpText": "……………………えっ",
                    "enText": "……………………Ehh",
