                    "origLen": 101,
                    "pathId": -3964155008024267500
                }
            ],
            "pathId": -1624819304168950954,
            "blockIdx": 38
        },
        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "力むことなくスタートを成功させ、前方のかなりいい位置をキープ。\n早めの時計でレースは流れていき――第4コーナー……！",
            "enText": "She had an effortless start, and took position at the front. \nThe race progressed quickly――and then at the fourth corner……!",
            "nextBlock": 40,
            "origClipLength": 120,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 168,
                    "pathId": 3733797770246100214
