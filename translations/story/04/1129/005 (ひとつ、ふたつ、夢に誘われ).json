            "pathId": -4511937257188038462,
            "blockIdx": 8
        },
        {
            "jpName": "アーモンドアイ",
            "enName": "Almond Eye",
            "jpText": "程よく体を温めて、眠気を促進していきましょう。\nさあ、召し上がれ♪",
            "enText": "Let's warm up that body from the inside \nto help you feel sleepy. Now, eat up♪",
            "nextBlock": 10,
            "origClipLength": 209,
            "voiceIdx": 7,
            "animData": [
                {
                    "origLen": 60,
                    "pathId": 6743271450026538138
