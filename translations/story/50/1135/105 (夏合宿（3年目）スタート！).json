            "pathId": 8861168843056692979,
            "blockIdx": 4
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "…………――",
            "enText": "",
            "nextBlock": 6,
            "origClipLength": 52,
            "voiceIdx": 60,
            "choices": [
                {
                    "jpText": "……ステゴ？",
                    "enText": "",
                    "nextBlock": 6
                }
            ],
            "animData": [
                {
                    "origLen": 63,
                    "pathId": 1744621405594824877
                },
                {
                    "origLen": 63,
                    "pathId": -3843137653171912320
                }
            ],
            "pathId": 5089772940573625143,
            "blockIdx": 5
        },
        {
            "jpName": "ステイゴールド",
            "enName": "Stay Gold",
            "jpText": "……『宝塚記念』の前後で、\nなんていうか……集まってくる感じがしてな。",
            "enText": "",
            "nextBlock": 7,
            "origClipLength": 90,
            "voiceIdx": 37,
            "animData": [
                {
                    "origLen": 13,
                    "pathId": -6985772930598366124
