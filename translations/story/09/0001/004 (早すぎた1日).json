            "pathId": -3404088496124697623,
            "blockIdx": 27
        },
        {
            "jpName": "先生B",
            "enName": "Teacher B",
            "jpText": "スペシャルウィーク……転入したてだから仕方ないが、\r\nこの点はちょっと……課題追加な。",
            "enText": "Special Week… Now, I know you're our new transfer, but this \nscore is… I think I'll have to assign you some extra work.",
            "nextBlock": 29,
            "origClipLength": 281,
