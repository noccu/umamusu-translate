            "blockIdx": 9
        },
        {
            "jpName": "アーモンドアイ",
            "enName": "Almond Eye",
            "jpText": "うそでしょ、どれもダメ！？",
            "enText": "You've gotta be kidding me, none of it worked!?",
            "nextBlock": 11,
            "origClipLength": 103,
            "voiceIdx": 8,
            "animData": [
                {
                    "origLen": 45,
                    "pathId": 7923378208387242715
