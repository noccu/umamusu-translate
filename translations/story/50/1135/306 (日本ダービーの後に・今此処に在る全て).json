            "origClipLength": 86,
            "voiceIdx": -1,
            "pathId": -2978792619138549679,
            "blockIdx": 2
        },
        {
            "jpName": "ステゴのファンB",
            "enName": "Stego Fan B",
            "jpText": "そこだ、ステゴーーっ！！！\n負けるなーーーーっ！！",
            "enText": "That's it Stegoーー!!! \nYou can't loseーー!!!",
