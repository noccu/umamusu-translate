        {
            "jpName": "モノローグ",
            "enName": "",
            "jpText": "時は、1か月前。学内模擬レースに遡る。",
            "enText": "One month ago, during a practice race at the academy…",
            "nextBlock": 5,
            "origClipLength": 69,
            "voiceIdx": -1,
            "animData": [
                {
                    "origLen": 40,
